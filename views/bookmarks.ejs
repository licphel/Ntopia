<h2>我的收藏</h2>
<% if (posts.length === 0) { %><p style="color:#999;text-align:center;padding:40px 0">暂无收藏。</p><% } %>
<% posts.forEach(function(p) { %>
<div class="forum-topic">
  <h3><a href="/posts/<%= p.slug %>"><%= p.title %></a></h3>
  <div class="forum-meta">
    By <a href="/users/<%= p.username %>"><%= p.display_name || p.username %></a> |
    <%= p.created_at.slice(0, 10) %> |
    收藏于 <%= p.bookmarked_at.slice(0, 10) %>
  </div>
</div>
<% }); %>
