<div style="max-width:480px;margin:60px auto;text-align:center;padding:32px 24px;border:var(--border-style) var(--border);background:#fff">
  <div style="font-size:48px;color:#ccc;font-weight:bold;margin-bottom:8px"><%= code %></div>
  <h3 style="color:var(--text);margin-bottom:8px;border:none;font-size:16px"><%= message %></h3>
  <p style="color:var(--text-muted);font-size:13px;margin-bottom:16px"><%= detail || '' %></p>
  <a href="<%= back || '/' %>" style="display:inline-block;background:var(--btn-accent-bg);color:var(--text-inverse);padding:6px 20px;border-radius:var(--radius);font-size:13px;text-decoration:none">返回</a>
</div>
