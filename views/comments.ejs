<div class="Post">
  <div class="PostHead">
    <div class="date-wrap <%= post.type === 'forum' ? 'forum-date' : '' %>">
      <span class="date-day"><%= new Date(post.created_at).getDate() %></span>
      <span class="date-month"><%= ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][new Date(post.created_at).getMonth()] %></span>
    </div>
    <div class="title-wrap">
      <h2><a href="/<%= post.type === 'forum' ? 'forum' : 'posts' %>/<%= post.slug %>"><%= post.title %></a></h2>
      <span class="submitted">
        <a href="/users/<%= post.username %>"><%= post.display_name || post.username %></a>
        <span class="lv-badge">Lv.<%= post.level || 1 %></span> |
        <%= post.created_at.slice(0, 10) %>
        | <a href="/<%= post.type === 'forum' ? 'forum' : 'posts' %>/<%= post.slug %>">← 返回</a>
      </span>
    </div>
  </div>
</div>

<h3>全部评论 (<%= comments.length %>)</h3>

<% comments.forEach(function(c) { %>
<div class="comment">
  <div class="cmt-header" style="display:block;margin-bottom:4px">
    <img src="<%= c.avatar || '/img/default-avatar.svg' %>" style="width:16px;height:16px;vertical-align:middle;margin-right:3px"><a href="/users/<%= c.username %>"><strong><%= c.display_name || c.username %></strong></a>
    <span class="lv-badge">Lv.<%= c.level || 1 %></span>
    <% if (c.parent_username) { %><span style="color:var(--c);font-size:11px"> 回复 @<%= c.parent_display || c.parent_username %></span><% } %>
    <span style="color:#999;font-size:11px;float:right"><%= c.created_at.slice(0, 16) %></span>
  </div>
  <div class="cmt-body" style="display:block;font-size:14px;line-height:1.7"><%- c.content_html %></div>
  <div style="margin-top:6px">
    <% if (user) { %>
      <button onclick="var f=document.getElementById('reply-<%= c.id %>');f.style.display=f.style.display==='none'?'block':'none';var ta=f.querySelector('textarea');ta.value='@<%= c.username %> ';ta.focus()" style="background:none;border:none;color:var(--c);cursor:pointer;font-size:11px">回复</button>
    <% } %>
    <% if (user && (user.id === c.author_id || user.role === 'admin')) { %>
      <form method="POST" action="/comments/<%= c.id %>/delete" style="display:inline" onsubmit="return confirm('确认删除？')">
        <button style="background:none;border:none;color:#c00;cursor:pointer;font-size:11px;padding:0">删除</button>
      </form>
    <% } %>
  </div>
  <% if (user) { %>
  <div id="reply-<%= c.id %>" style="display:none;margin-top:6px">
    <form method="POST" action="/posts/<%= post.slug %>/comment">
      <input type="hidden" name="parent_id" value="<%= c.id %>">
      <textarea name="content" placeholder="回复 @<%= c.username %>..." style="width:100%;min-height:50px;padding:6px;border:1px solid #ddd;border-radius:3px;font-size:13px;font-family:inherit"></textarea>
      <button type="submit" class="cmt-btn" style="font-size:12px;padding:3px 10px;margin-top:3px">回复</button>
    </form>
  </div>
  <% } %>
</div>
<% }); %>

<% if (user) { %>
<div class="comment-form" style="margin-top:20px">
  <h4>发表评论</h4>
  <form method="POST" action="/posts/<%= post.slug %>/comment">
    <%- include('comment-toolbar') %>
    <textarea name="content" placeholder="支持 Markdown 和数学公式..."></textarea>
    <button type="submit" class="cmt-btn">提交评论</button>
  </form>
</div>
<% } else { %>
<p style="color:#999;margin-top:20px">请<a href="/auth/login">登录</a>后发表评论。</p>
<% } %>
