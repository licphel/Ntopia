<div class="auth-form">
  <h2>注册</h2>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="auth-error"><%= error %></div>
  <% } %>
  <form method="POST" action="/auth/register">
    <label>用户名</label>
    <input type="text" name="username" required placeholder="至少2个字符">
    <label>显示名称</label>
    <input type="text" name="display_name" placeholder="可选，默认为用户名">
    <label>密码</label>
    <input type="password" name="password" required placeholder="至少4个字符">
    <label>确认密码</label>
    <input type="password" name="password2" required>
    <button type="submit" class="submit-btn">注册</button>
  </form>
  <p style="text-align:center;margin-top:12px;font-size:13px">已有账号？<a href="/auth/login">立即登录</a></p>
</div>
