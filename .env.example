PORT=3000
SESSION_SECRET={RANDOM STRING}

# SMTP — 邮件由服务端发送，请使用服务器所在地区可访问的 SMTP
# QQ邮箱（国内推荐）：
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=你的QQ号@qq.com
SMTP_PASS=QQ邮箱授权码（设置-账户-POP3/SMTP服务-生成授权码）
SMTP_FROM=你的QQ号@qq.com

# Gmail（海外服务器）：
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=你的@gmail.com
# SMTP_PASS=Google应用密码

OWNER_NAME=admin
OWNER_PASSWORD=admin123
OWNER_EMAIL=admin@ntopia.top

# 内容核查 LLM API
DEEPSEEK_API_KEY=sk-xxx

# 删除延期
RETENTION=60 days
