<div class="flex-between" style="margin-bottom:8px">
  <h2 style="font-size:16px;color:var(--c);margin:0"><a href="/forum/<%= section.id %>"><%= section.name %></a> 的关注者</h2>
</div>

<% if (followers && followers.length) { %>
  <% followers.forEach(function(u) { %>
  <div style="padding:6px 0;border-bottom:1px dotted var(--border);display:flex;align-items:center;gap:10px">
    <img src="<%= u.avatar || '/img/default-avatar.png' %>" style="width:32px;height:32px;border-radius:var(--radius)">
    <div>
      <%- include('widget/user-name', { u: u }) %>
      <span style="color:var(--text-muted);font-size:11px;margin-left:6px"><%- timeTag(u.created_at) %></span>
    </div>
  </div>
  <% }); %>
<% } else { %>
  <p style="color:var(--text-muted);text-align:center;padding:40px 0">暂无关注者。</p>
<% } %>
