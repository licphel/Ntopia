<div id="SideBar">
  <% if (typeof posters !=='undefined' && posters && posters.length) { %>
    <div class="sb-box" style="padding:0;overflow:hidden">
      <div id="PosterBar" style="aspect-ratio:7/2;background:#1a1a1a">
        <% posters.forEach(function(p, i) { %>
          <img src="<%= p %>" alt="" class="<%= i === 0 ? 'active' : '' %>" data-idx="<%= i %>">
          <% }); %>
            <% if (posters.length> 1) { %>
              <button class="p-arrow left" onclick="posterPrev()">&#10094;</button>
              <button class="p-arrow right" onclick="posterNext()">&#10095;</button>
              <div class="p-dots">
                <% posters.forEach(function(p, i) { %><span class="<%= i === 0 ? 'active' : '' %>" data-idx="<%= i %>"
                    onclick="posterGo(<%= i %>)"></span>
                  <% }); %>
              </div>
              <% } %>
      </div>
    </div>
    <% } %>
      <div class="sb-box">
        <h3>关于站长</h3>
        <div class="sb-inner">
          <div style="overflow:hidden;margin-bottom:6px">
            <a href="/users/<%= admin.id %>"><img src="<%= admin.avatar || '/img/default-avatar.png' %>"
                style="width:48px;height:48px;border:2px var(--border-style) var(--border);float:left;margin:2px 10px 6px 0"
                alt=""></a>
            <a href="/users/<%= admin.id %>" style="font-weight:bold;font-size:14px">
              <%= admin.display_name || admin.username %>
            </a>
            <span style="font-size:10px;color:var(--text-muted);margin-left:4px">@<%= admin.username %></span>
            <% if (admin.bio) { %>
              <div style="font-size:12px;color:var(--text-soft);margin-top:3px;line-height:1.5">
                <%= admin.bio.slice(0, 64) %>
              </div>
              <% } %>
          </div>
          <div style="font-size:11px;color:var(--text-muted);line-height:1.6;clear:both">
            创建于 Ntopia，致力于构建一个自由、理性的知识交流社区。欢迎所有热爱思考的朋友。
          </div>
        </div>
      </div>

      <% if (recentPosts && recentPosts.length) { %>
        <div class="sb-box">
          <h3>最新文章</h3>
          <div class="sb-inner">
            <ul>
              <% recentPosts.forEach(function(p) { %>
                <li><a href="/posts/<%= p.id %>">
                    <%= p.title %>
                  </a></li>
                <% }); %>
            </ul>
          </div>
        </div>
        <% } %>

          <% if (recentComments && recentComments.length) { %>
            <div class="sb-box">
              <h3>最近评论</h3>
              <div class="sb-inner">
                <ul>
                  <% recentComments.forEach(function(c) { %>
                    <li style="margin-bottom:6px;padding-bottom:4px;border-bottom:1px dotted var(--border-light)">
                      <a href="/users/<%= c.author_id || '' %>" style="font-weight:bold"><%= c.display_name || c.username %></a>
                      <span style="font-size:10px;color:var(--text-muted)"> | <%- timeTag(c.created_at, {fmt:'short'}) %></span>
                      <span style="font-size:10px;color:var(--text-muted)"> 于 <a href="/posts/<%= c.post_id %>"><%= (c.post_title || '').slice(0,20) %></a>：</span>
                      <span style="font-size:11px"><%= (c.cmt_content || '' ).replace(/<[^>]*>/g, '').slice(0, 40) %></span>
                    </li>
                    <% }); %>
                </ul>
              </div>
            </div>
            <% } %>

              <% if (typeof stats !=='undefined' && stats) { %>
                <div class="sb-box">
                  <h3>站点统计</h3>
                  <div class="sb-inner" style="font-size:12px;line-height:1.8">
                    文章 <%= stats.posts %> 篇 · 评论 <%= stats.comments %> 条 · 用户 <%= stats.users %> 人<br>
                          访问 <%= stats.views %> 次 · 点赞 <%= stats.likes %> · 签到 <%= stats.checkins %>
                  </div>
                </div>
                <% } %>
                  <div class="sb-box">
                    <h3>友情链接</h3>
                    <div class="sb-inner">
                      <ul>
                        <li><a href="https://kexue.fm" target="_blank" rel="noopener">科学空间</a></li>
                        <li><a href="https://licphel.github.io" target="_blank" rel="noopener">Licphel 个人主页</a></li>
                      </ul>
                    </div>
                  </div>

</div>