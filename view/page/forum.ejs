<% if (typeof followedSections !== 'undefined' && followedSections.length) { %>
<!-- 我关注的板块 -->
<div style="margin-bottom:16px">
  <h3 style="font-size:14px;color:var(--c);margin:0 0 6px 0">我关注的板块</h3>
  <% followedSections.forEach(function(s){ %>
  <div style="padding:6px 0;border-bottom:1px dotted var(--border);display:flex;align-items:flex-start;gap:10px">
    <% if (s.image) { %><img src="<%= s.image %>" style="width:32px;height:32px;border-radius:var(--radius);object-fit:cover;flex-shrink:0;margin-top:2px"><% } else { %><div style="width:32px;height:32px;border-radius:var(--radius);background:var(--c);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:14px;color:var(--text-inverse);font-weight:bold;margin-top:2px"><%= (s.name||'?')[0] %></div><% } %>
    <div style="flex:1;min-width:0">
      <a href="/forum/<%= s.id %>" style="font-weight:bold;font-size:13px;color:var(--text)"><%= s.name %></a>
      <span style="font-size:11px;color:var(--c);margin-left:6px"><%= s.post_count || 0 %> 帖</span>
    </div>
  </div>
  <% }) %>
</div>
<% } %>

<!-- 热议板块 header -->
<div class="flex-between" style="margin-bottom:8px">
  <h2 style="font-size:16px;color:var(--c);margin:0;padding-bottom:6px;border-bottom:2px solid var(--border)">热议板块</h2>
  <a href="/forum/sections" style="font-size:11px;color:var(--c);white-space:nowrap">所有板块</a>
</div>

<% if (sections && sections.length) { %>
<div style="margin-bottom:16px">
  <% sections.forEach(function(s){ %>
  <div style="padding:8px 0;border-bottom:1px dotted var(--border);display:flex;align-items:flex-start;gap:10px">
    <% if (s.image) { %><img src="<%= s.image %>" style="width:32px;height:32px;border-radius:var(--radius);object-fit:cover;flex-shrink:0;margin-top:2px"><% } %>
    <div style="flex:1;min-width:0">
      <a href="/forum/<%= s.id %>" style="font-weight:bold;font-size:14px;color:var(--text)"><%= s.name %></a>
      <span style="font-size:11px;color:var(--c);margin-left:8px"><%= s.post_count || 0 %> 帖</span>
      <% if (s.description) { %><div style="font-size:12px;color:var(--text-muted);margin-top:2px"><%= s.description %></div><% } %>
    </div>
  </div>
  <% }) %>
</div>
<% } else { %>
<p style="color:var(--text-muted);text-align:center;padding:40px 0">暂无板块。</p>
<% } %>

<%- include('widget/pagination', { page: page || 1, totalPages: totalPages || 1, baseUrl: '/forum', param: 'page' }) %>

<!-- 创建板块 → top right, auth-guarded -->
<div class="flex-between" style="margin-bottom:8px;margin-top:20px">
  <% if (locals.user && (locals.user.level >= 5 || (locals.user.role||0) >= 16)) { %>
  <button onclick="showCreate()" style="background:var(--btn-accent-bg);color:var(--text-inverse);border:none;padding:3px 10px;border-radius:var(--radius);cursor:pointer;font-size:11px;white-space:nowrap">创建板块</button>
  <% } %>
</div>

<% if (locals.user && (locals.user.level >= 5 || (locals.user.role||0) >= 16)) { %>
<form id="createForm" action="/forum/sections" method="post" style="display:none;margin-bottom:14px;padding:10px 14px;background:var(--bg-card);border:var(--border-style) var(--border);border-radius:var(--radius)">
  <input type="hidden" name="_csrf" value="<%= locals.csrf %>">
  <div style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap">
    <div><label style="font-size:11px;color:var(--text-soft);display:block">名称</label><input name="name" required maxlength="64" style="padding:4px 8px;border:1px solid var(--border-input);border-radius:var(--radius);font:12px Georgia,serif;width:140px"></div>
    <div><label style="font-size:11px;color:var(--text-soft);display:block">简介</label><input name="description" maxlength="200" style="padding:4px 8px;border:1px solid var(--border-input);border-radius:var(--radius);font:12px Georgia,serif;width:200px"></div>
    <button style="background:var(--btn-accent-bg);color:var(--text-inverse);border:none;padding:4px 12px;border-radius:var(--radius);cursor:pointer;font-size:12px">创建</button>
    <button type="button" onclick="document.getElementById('createForm').style.display='none'" style="background:none;border:1px solid var(--border-light);padding:4px 12px;border-radius:var(--radius);cursor:pointer;font-size:12px">取消</button>
  </div>
</form>
<% } %>


<script>function showCreate(){document.getElementById('createForm').style.display='block'}</script>
