PORT=3000
SESSION_SECRET={RANDOM STRING}

# SMTP — 邮件由服务端发送，请使用服务器所在地区可访问的 SMTP
# QQ邮箱（国内推荐）：
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=你的QQ号@qq.com
SMTP_PASS=QQ邮箱授权码（设置-账户-POP3/SMTP服务-生成授权码）
SMTP_FROM=你的QQ号@qq.com

# Gmail（海外服务器）：
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=你的@gmail.com
# SMTP_PASS=Google应用密码

OWNER_NAME=admin
OWNER_PASSWORD=admin123
OWNER_EMAIL=admin@ntopia.top

# 内容核查 LLM API（设置后启用 AI 审核）
DEEPSEEK_API_KEY=sk-xxx
ENABLE_MODERATION=false

# 删除延期
RETENTION=60 days

# Cloudflare R2 对象存储（设置后图片/附件存储到 R2，不占服务器空间）
# 获取方式：Cloudflare Dashboard → R2 → 创建存储桶 → 管理 API 令牌
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY=xxx
R2_SECRET_KEY=xxx
R2_BUCKET=ntopia
R2_PUBLIC_URL=https://cdn.ntopia.top
