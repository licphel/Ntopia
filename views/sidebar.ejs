<div id="SideBar">

  <div class="sb-box">
    <h3>关于站长</h3>
    <div class="sb-inner">
      <div style="overflow:hidden;margin-bottom:4px">
        <a href="/users/<%= admin.username %>"><img src="<%= admin.avatar || '/img/default-avatar.svg' %>" style="width:48px;height:48px;border:2px solid #e0dbd0;float:left;margin:1px 8px 4px 0" alt=""></a>
        <a href="/users/<%= admin.username %>" style="font-weight:bold"><%= admin.display_name || admin.username %></a>
        <span style="font-size:12px;line-height:1.6;color:#666"><br><%= admin.bio%></span>
      </div>
      <div style="font-size:11px;color:#888;line-height:1.5;clear:both">
        欢迎交流讨论。可通过论坛或私信联系。回复未必及时，必要时可写邮件。
      </div>
    </div>
  </div>

  <div class="sb-box">
    <h3>站内搜索</h3>
    <div class="sb-inner">
      <form method="GET" action="/search" style="display:flex;gap:2px">
        <input type="text" name="q" placeholder="输入关键词..." style="flex:1;padding:3px 6px;border:1px solid #ccc;font-size:12px;font-family:inherit">
        <button type="submit" style="background:#058c05;color:#fff;border:none;padding:3px 8px;cursor:pointer;font-size:11px">搜索</button>
      </form>
    </div>
  </div>

  <% if (recentPosts && recentPosts.length) { %>
  <div class="sb-box">
    <h3>最新文章</h3>
    <div class="sb-inner">
      <ul>
        <% recentPosts.forEach(function(p) { %>
          <li><a href="/posts/<%= p.slug %>"><%= p.title %></a></li>
        <% }); %>
      </ul>
    </div>
  </div>
  <% } %>

  <% if (recentComments && recentComments.length) { %>
  <div class="sb-box">
    <h3>最近评论</h3>
    <div class="sb-inner">
      <ul>
        <% recentComments.forEach(function(c) { %>
          <li style="margin-bottom:6px;padding-bottom:4px;border-bottom:1px dotted #eee">
            <a href="/<%= c.post_type === 'forum' ? 'forum' : 'posts' %>/<%= c.post_slug %>" style="color:#adcb83"><%= c.display_name || c.username %></a>:
            <span style="color:#888;font-size:11px"><%= (c.cmt_content || '').replace(/<[^>]*>/g, '').slice(0, 40) %></span>
          </li>
        <% }); %>
      </ul>
    </div>
  </div>
  <% } %>

  <% if (tagList && tagList.length) { %>
  <div class="sb-box">
    <h3>热门标签</h3>
    <div class="sb-inner tag-cloud">
      <% tagList.forEach(function(t) { %>
        <a href="/search?q=<%= encodeURIComponent(t) %>&type=posts"><%= t %></a>
      <% }); %>
    </div>
  </div>
  <% } %>

  <div class="sb-box">
    <h3>友情链接</h3>
    <div class="sb-inner">
      <ul>
        <li><a href="https://kexue.fm" target="_blank" rel="noopener">科学空间</a></li>
        <li><a href="https://licphel.github.io" target="_blank" rel="noopener">Licphel 个人主页</a></li>
      </ul>
    </div>
  </div>

</div>
