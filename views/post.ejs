<div class="Post">
  <div class="PostHead">
    <div class="date-wrap">
      <span class="date-day"><%= new Date(post.created_at).getDate() %></span>
      <span class="date-month"><%= ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][new Date(post.created_at).getMonth()] %></span>
    </div>
    <div class="title-wrap">
      <h2><%= post.title %></h2>
      <span class="submitted">
        <img src="<%= post.avatar || '/img/default-avatar.svg' %>" style="width:20px;height:20px;border-radius:2px;vertical-align:middle;margin-right:3px">
        <a href="/users/<%= post.username %>"><%= post.display_name || post.username %></a>
<% var b = roleBadge(post.role || 0); %>
        <span class="lv-badge" data-level="LEVEL=<%= post.role %>" style="background:<%= b.bg %>;color:<%= b.color %>"><%= b.text %></span>
        <span class="lv-badge">Lv.<%= post.level || 1 %></span> |
        <%= post.created_at.slice(0, 10) %>
        <% if (post.category) { %> | <%= post.category_name || post.category %><% } %>
        | <%= post.view_count %> 阅读
        | <a href="#" onclick="toggleLike(event, <%= post.id %>, null)" id="like-post-<%= post.id %>" style="font-size:11px;color:#999">点赞</a>
        | <a href="#" onclick="toggleBookmark(event, <%= post.id %>)" id="bookmark-<%= post.id %>" style="font-size:11px;color:#999">收藏</a>
        <% if (user && (user.id === post.author_id || (user.role || 0) >= 32)) { %>
          | <a href="/posts/<%= post.slug %>/edit">编辑</a>
          | <form method="POST" action="/posts/<%= post.slug %>/delete-self" style="display:inline" onsubmit="return confirm('确认删除？')">
              <button style="background:none;border:none;color:#c00;cursor:pointer;font-size:11px;padding:0">删除</button>
            </form>
        <% } %>
      </span>
    </div>
  </div>
  <div class="PostContent"><%- post.content_html %></div>
  <% if (post.tags) { %>
  <div class="tools">标签: <% post.tags.split(',').forEach(function(t) { %><a href="/search?q=<%= encodeURIComponent(t.trim()) %>"><%= t.trim() %></a> <% }); %></div>
  <% } %>
</div>

<!-- Top-level comments only (like Tieba) -->
<div style="margin-top:20px">
  <h3>评论 (<%= comments.filter(function(c){return !c.parent_id}).length %>)</h3>
  <% comments.filter(function(c){return !c.parent_id}).forEach(function(c) { %>
  <div class="comment" style="padding:10px 14px;margin-bottom:8px">
    <div style="margin-bottom:4px">
      <img src="<%= c.avatar || '/img/default-avatar.svg' %>" style="width:16px;height:16px;vertical-align:middle;margin-right:3px"><a href="/users/<%= c.username %>"><strong><%= c.display_name || c.username %></strong></a>
      <span class="lv-badge">Lv.<%= c.level || 1 %></span>
      <span style="color:#999;font-size:10px;float:right"><%= c.created_at.slice(5, 16) %></span>
    </div>
    <div style="font-size:14px;line-height:1.7"><%- c.content_html %></div>
    <div style="margin-top:6px;font-size:12px">
      <% var rc = comments.filter(function(x){return x.parent_id === c.id}).length; %>
      <a href="/posts/<%= post.slug %>/comment/<%= c.id %>" style="color:var(--c)"><%= rc > 0 ? rc + ' 条回复' : '回复' %></a>
      <% if (user) { %>
        <button onclick="var f=document.getElementById('reply-<%= c.id %>');f.style.display=f.style.display==='none'?'block':'none';var ta=f.querySelector('textarea');ta.value='@<%= c.username %> ';ta.focus()" style="background:none;border:none;color:var(--c);cursor:pointer;font-size:11px;margin-left:8px">快速回复</button>
      <% } %>
      <% if (user && (user.id === c.author_id || (user.role || 0) >= 32)) { %>
        <form method="POST" action="/comments/<%= c.id %>/delete" style="display:inline;margin-left:8px" onsubmit="return confirm('确认删除？')">
          <button style="background:none;border:none;color:#c00;cursor:pointer;font-size:11px;padding:0">删除</button>
        </form>
      <% } %>
    </div>
    <% if (user) { %>
    <div id="reply-<%= c.id %>" style="display:none;margin-top:6px">
      <form method="POST" action="/posts/<%= post.slug %>/comment">
        <input type="hidden" name="parent_id" value="<%= c.id %>">
        <%- include('comment-toolbar') %>
        <textarea name="content" placeholder="回复 @<%= c.username %>..." style="width:100%;min-height:40px;padding:4px;border:1px solid #ddd;border-radius:3px;font-size:12px;font-family:inherit"></textarea>
        <button type="submit" class="cmt-btn" style="font-size:11px;padding:2px 8px;margin-top:2px">回复</button>
      </form>
    </div>
    <% } %>
  </div>
  <% }); %>
</div>

<% if (user) { %>
<div style="margin-top:4px;padding:10px 0">
  <form method="POST" action="/posts/<%= post.slug %>/comment">
    <%- include('comment-toolbar') %>
    <textarea name="content" placeholder="发表新评论..." style="width:100%;min-height:60px;padding:6px;border:1px solid #ddd;border-radius:3px;font-size:13px;font-family:inherit"></textarea>
    <button type="submit" class="cmt-btn" style="margin-top:4px">发表评论</button>
  </form>
</div>
<% } %>
