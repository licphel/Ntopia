<h2>我的收藏</h2>
<% if (posts.length === 0) { %><p style="color:#999;text-align:center;padding:40px 0">暂无收藏。</p><% } %>
<% posts.forEach(function(p) { %>
<div class="forum-topic" style="display:flex;justify-content:space-between;align-items:center">
  <div style="flex:1">
    <h3><a href="/posts/<%= p.slug %>"><%= p.title %></a></h3>
    <div class="forum-meta">
      By <a href="/users/<%= p.username %>"><%= p.display_name || p.username %></a> |
      <%- timeTag(p.created_at) %> |
      收藏于 <%- timeTag(p.bookmarked_at, {fmt:'short'}) %>
    </div>
  </div>
  <button onclick="removeBookmark(event, <%= p.id %>)" style="background:none;border:none;color:#c00;cursor:pointer;font-size:11px;padding:2px 6px;white-space:nowrap;flex-shrink:0">取消收藏</button>
</div>
<% }); %>

<%- include('pagination', { page: bmPage, totalPages: bmTotalPages, baseUrl: '/bookmarks', param: 'page' }) %>

<script>
async function removeBookmark(e, postId) {
  e.preventDefault();
  var ok = await ntopiaConfirm('取消收藏？'); if (!ok) return;
  var resp = await fetch('/bookmarks/toggle', { method:'POST', headers:{'Content-Type':'application/json','x-csrf-token':'<%= csrf %>'}, body:JSON.stringify({post_id:postId}) });
  var d = await resp.json();
  if (d.ok) location.reload();
}
</script>
