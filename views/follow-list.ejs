<h2><a href="/users/<%= profile.username %>"><%= profile.display_name || profile.username %></a> 的<%= listType === 'followers' ? '粉丝' : '关注' %></h2>

<% if (users.length === 0) { %>
  <p style="color:#999;text-align:center;padding:40px 0">空空如也~</p>
<% } %>

<% users.forEach(function(u) { %>
<div class="forum-topic" style="display:flex;align-items:center;gap:12px">
  <img src="<%= u.avatar || '/img/default-avatar.png' %>" style="width:40px;height:40px;border:2px solid #e0dbd0">
  <div style="flex:1">
    <a href="/users/<%= u.username %>" style="font-weight:bold;font-size:14px"><%= u.display_name || u.username %></a>
    <span style="color:#999;font-size:12px;margin-left:4px">@<%= u.username %></span>
    <div style="font-size:11px;color:#999"><%= (u.bio || '').slice(0, 60) %></div>
  </div>
  <% if (user && user.id !== u.id) { %>
    <a href="#" onclick="toggleFollow(this,'<%= u.username %>');return false" style="font-size:11px;color:<%= u.isFollowed ? '#999' : 'var(--c)' %>;white-space:nowrap"><%= u.isFollowed ? '已关注' : '+ 关注' %></a>
  <% } %>
  <div style="font-size:11px;color:#999"><%- timeTag(u.followed_at, {fmt:'date'}) %></div>
</div>
<% }); %>

<%- include('pagination', { page: page, totalPages: totalPages, baseUrl: '/follow/' + profile.username + '/' + listType, param: 'page' }) %>
