<% var isSecMod = user && ((typeof sectionModId !== 'undefined' && user.id === sectionModId) || (typeof sectionSubModIds !== 'undefined' && sectionSubModIds.has(user.id))); %>
<div style="margin-bottom:16px">
  <a href="/<%= 'posts' %>/<%= post.id %>" style="font-size:13px">返回 <%= '文章' %></a>
  <span style="color:var(--text-muted);font-size:13px;margin-left:8px">
    <%= post.title %>
  </span>
</div>

<div class="comment" style="padding:12px 14px;margin-bottom:12px;border:2px solid var(--c)">
  <div style="margin-bottom:6px">
    <% if (root.is_deleted) { %><span style="color:var(--text-danger);font-size:10px">[已删除]</span>
      <% } %><img src="<%= root.avatar || '/img/default-avatar.png' %>" style="width:20px;height:20px;vertical-align:middle;margin-right:3px"><% var rIsStaff = (typeof sectionModId !== 'undefined' && root.author_id === sectionModId) || (typeof sectionSubModIds !== 'undefined' && sectionSubModIds.has(root.author_id)); %>
<%- include('widget/user-name', rIsStaff ? { u: root, color: '#2b7cbe', label: '操作员' } : { u: root }) %>
        <span style="color:var(--text-muted);font-size:11px;float:right">
          <%- timeTag(root.created_at) %>
        </span>
  </div>
  <div style="font-size:14px;line-height:1.7"><%- root.content_html %></div>
  <div style="margin-top:8px">
    <% if (user && (user.id===root.author_id || (user.role || 0)>= 32 || isSecMod)) { %>
      <form method="POST" action="/<%= 'posts' %>/comments/<%= root.id %>/delete" style="display:inline"
        onsubmit="return confirm('确认删除？')">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <button
          style="background:none;border:none;color:var(--text-danger);cursor:pointer;font-size:11px;padding:0">删除</button>
      </form>
      <% } %>
  </div>
</div>

<h4>回复 (<%= replyCount %>)</h4>
<% replies.forEach(function(c) { %>
  <div class="comment"
    style="padding:4px 10px;margin-bottom:3px;<%= c.is_deleted ? 'opacity:0.5;border-color:var(--text-danger)' : '' %>">
    <div style="margin-bottom:1px;line-height:1.5">
      <% if (c.is_deleted) { %><span style="color:var(--text-danger);font-size:10px">[已删除]</span>
        <% } %>
          <img src="<%= c.avatar || '/img/default-avatar.png' %>"
            style="width:16px;height:16px;vertical-align:middle;margin-right:3px">
          <% var cIsStaff = (typeof sectionModId !== 'undefined' && c.author_id === sectionModId) || (typeof sectionSubModIds !== 'undefined' && sectionSubModIds.has(c.author_id)); %>
          <%- include('widget/user-name', cIsStaff ? { u: c, color: '#2b7cbe', label: '操作员' } : { u: c }) %>
          <% if (c.parent_username && c.parent_id !==root.id) { %><span style="color:var(--c);font-size:11px"> 回复 @<%=
                c.parent_display || c.parent_username %></span>
            <% } %>
              <span style="color:var(--text-muted);font-size:10px;margin-left:4px"><%- timeTag(c.created_at,
                  {fmt:'short'}) %></span>
              <% if (user) { %><a href="/posts/<%= post.id %>/comment/<%= c.id %>"
                  style="font-size:10px;color:var(--c);margin-left:4px">回复</a>
                <% } %>
                  <% if (user && (user.id===c.author_id || (user.role || 0)>= 32 || isSecMod)) { %>
                    <form method="POST" action="/posts/comments/<%= c.id %>/delete" style="display:inline"
                      onsubmit="return confirm('确认删除？')"><input type="hidden" name="_csrf" value="<%= csrf %>"><button
                        style="background:none;border:none;color:var(--text-danger);cursor:pointer;font-size:10px;padding:0;margin-left:4px">删除</button>
                    </form>
                    <% } %>
    </div>
    <div style="font-size:13px;line-height:1.6"><%- c.content_html %></div>
  </div>
  <% }); %>

    <% if (user) { %>
      <div class="comment-form" style="margin-top:16px">
        <h4>回复此评论</h4>
        <form method="POST" action="/<%= 'posts' %>/<%= post.id %>/comment">
          <input type="hidden" name="_csrf" value="<%= csrf %>">
          <input type="hidden" name="parent_id" value="<%= root.id %>">
          <%- include('widget/comment-toolbar') %>
            <textarea name="content" placeholder="回复 @<%= root.display_name || root.username %>..."></textarea>
            <button type="submit" class="cmt-btn">提交回复</button>
        </form>
      </div>
      <% } else { %>
        <p style="color:var(--text-muted);margin-top:16px">请<a href="/auth/login">登录</a>后回复。</p>
        <% } %>

          <input type="hidden" name="_csrf" value="<%= csrf %>">