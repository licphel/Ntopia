<div style="max-width:480px;margin:60px auto;text-align:center;padding:32px 24px;border:1px solid #e0dbd0;background:#fff">
  <div style="font-size:48px;color:#ccc;font-weight:bold;margin-bottom:8px"><%= code %></div>
  <h3 style="color:#333;margin-bottom:8px;border:none;font-size:16px"><%= message %></h3>
  <p style="color:#999;font-size:13px;margin-bottom:16px"><%= detail || '' %></p>
  <a href="<%= back || '/' %>" style="display:inline-block;background:#058c05;color:#fff;padding:6px 20px;border-radius:2px;font-size:13px;text-decoration:none">返回</a>
</div>
