<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> — Ntopia</title>
<link rel="icon" href="/img/favicon.svg" type="image/svg+xml">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/themes/prism-tomorrow.min.css">
<script>
MathJax = { tex: {inlineMath: [['$','$'],['\\(','\\)']], displayMath: [['$$','$$'],['\\[','\\]']]}, svg: {fontCache:'global'} };
</script>
<script async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-svg.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#ddd8cc;color:#333;font:14px/1.7 Georgia,"Times New Roman","Noto Serif SC",serif}
a{color:var(--c);text-decoration:none}
a:hover{color:var(--cd);text-decoration:underline}
#Container{max-width:960px;margin:10px auto;background:#fffef9;border:1px solid #ccc;box-shadow:0 1px 4px rgba(0,0,0,.06)}

/* === Header === */
#Header{display:flex;flex-wrap:wrap;justify-content:space-between;padding:14px 0 0;background:linear-gradient(to bottom,#fafaf5,#fffef9)}
#HeadLeft{flex:1;padding:0 20px}
#HeadLeft h1{font-size:22px;font-weight:bold;letter-spacing:1px}
#HeadLeft h1 a{color:#333}#HeadLeft h1 a:hover{color:var(--c);text-decoration:none}
#navigation{color:#999;font-size:12px;font-style:italic;margin-top:1px}
#MenuTop{width:100%;margin:10px 0 0 0;padding:7px 20px;background:var(--c)}
#MenuTop ul{list-style:none;display:flex;flex-wrap:wrap;gap:0;align-items:center}
#MenuTop li{display:flex;align-items:center}
#MenuTop li+li::before{content:"·";color:rgba(255,255,255,0.4);margin:0 7px;font-weight:bold}
#MenuTop a,#MenuTop .nav-btn{font-size:12px;color:rgba(255,255,255,0.85);text-decoration:none}
#MenuTop a:hover,#MenuTop a.nav-active,#MenuTop .nav-btn:hover{color:#fff;text-decoration:none}
#MenuTop a.nav-active{font-weight:bold}
#MenuTop .notif-badge{background:#fff;color:var(--c);top:-6px;right:-10px}
#HeadRight{display:flex;gap:12px;text-align:center;font-size:11px;flex-shrink:0;padding:0 20px}
#HeadRight a{color:#555;display:block;width:52px}
#HeadRight a:hover{color:var(--c);text-decoration:none}
#HeadRight .hr-icon{display:block;font-size:26px;line-height:1.2;margin-bottom:1px}
#Submissions{margin-top:8px;font-size:11px;color:#999;line-height:1.5}

/* === UserBar === */
#UserBar{text-align:right;padding:4px 20px;background:#f8f6f0;border-bottom:1px solid #e0dbd0;font-size:11px;color:#666}
#UserBar a{color:var(--c);font-weight:bold}
#UserBar .checkin-btn{background:var(--c);color:#fff;border:none;padding:1px 10px;border-radius:2px;cursor:pointer;font-size:11px;margin:0 3px}
#UserBar .checkin-btn:hover{background:var(--cd)}
#UserBar .checkin-btn.done{background:#aaa;cursor:default}
#UserBar .xp-badge{display:inline-block;background:var(--cbg);color:var(--c);padding:0 6px;border-radius:2px;margin:0 3px;font-weight:bold;font-size:10px}

/* === InfoBar (HeadUn style) === */
#InfoBar{padding:12px 20px;background:#fafaf5;border-bottom:1px solid #ddd}
#InfoBar .ib-block{padding:0 0 10px 0;margin-bottom:8px;border-bottom:1px dotted #e0dbd0;font-size:12px;line-height:1.7}
#InfoBar .ib-block:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0}
#InfoBar .ib-block h3{font-size:14px;color:var(--c);margin-bottom:2px}
#InfoBar .ib-block p{color:#777}

/* === Layout === */
#MainBody{display:flex;gap:18px;padding:16px 20px}
#content{flex:1;min-width:0}

/* === Post === */
.Post{margin-bottom:24px;padding-bottom:20px;border-bottom:2px solid #e0dbd0}
.Post.pinned{border-left:3px solid var(--c);padding-left:12px}
.Post:last-child,.Post:only-child{border-bottom:none}
.PostHead{display:flex;gap:12px;align-items:flex-start}
.date-wrap{text-align:center;background:var(--c);color:#fff;padding:3px 8px 4px;border-radius:2px;min-width:44px;flex-shrink:0;box-shadow:1px 1px 2px rgba(0,0,0,.1)}
.date-wrap.forum-date{background:#6a8a4e}
.date-day{display:block;font-size:20px;font-weight:bold;line-height:1.1}
.date-month{display:block;font-size:10px;text-transform:uppercase}
.title-wrap h2{font-size:18px;margin-bottom:2px;line-height:1.3}
.title-wrap h2 a{color:#333}.title-wrap h2 a:hover{color:var(--c)}
.submitted{font-size:11px;color:#999}.submitted a{color:var(--c)}
.lv-badge{font-size:10px;padding:0 4px;border-radius:2px;font-weight:bold;margin-left:2px;cursor:default}
.lv-badge[data-level]{position:relative}
.lv-badge[data-level]:hover::after{content:attr(data-level);position:absolute;top:-18px;left:0;background:#333;color:#fff;font-size:10px;padding:1px 5px;border-radius:2px;white-space:nowrap;z-index:10}
.PostContent{margin-top:8px;font-size:14px}
.PostContent p{margin:6px 0}
.tools{margin-top:6px;font-size:11px;color:#999;display:flex;gap:8px;flex-wrap:wrap}

/* === Sidebar === */
#SideBar{width:260px;flex-shrink:0}
#SideBar .sb-box{margin-bottom:12px;border:1px solid #d5d0c5;background:#fff;
  box-shadow:0 1px 0 #fff inset,0 -1px 0 #e8e4d8 inset,0 0 0 1px #e8e4d8,0 1px 3px rgba(0,0,0,.04);
  border-radius:3px;overflow:hidden}
#SideBar .sb-box h3{font-size:13px;color:var(--c);padding:7px 12px 4px;border-bottom:1px solid #eee;margin-bottom:2px;font-weight:bold;background:#fafaf5}
#SideBar .sb-box .sb-inner{padding:3px 12px 8px;font-size:12px;line-height:1.65}
#SideBar ul{list-style:none}
#SideBar li{margin-bottom:2px;padding-left:12px;position:relative}
#SideBar li::before{content:">";color:var(--cl);position:absolute;left:0;font-weight:bold;font-size:11px;line-height:1.5}
#SideBar li a{color:#444;font-size:12px}#SideBar li a:hover{color:var(--c)}
.tag-cloud{display:flex;flex-wrap:wrap;gap:2px}
.tag-cloud a{font-size:11px;padding:1px 5px;background:var(--cbg);border-radius:2px;color:var(--c)}
.tag-cloud a:hover{background:var(--c);color:#fff;text-decoration:none}

/* === Footer === */
#Footer{padding:12px 20px;text-align:center;font-size:11px;color:#999;border-top:2px solid var(--c);background:#fafaf5;line-height:1.8}
#Footer a{color:var(--c)}

/* === Content Typography === */
#content h2{font-size:19px;margin:20px 0 8px;color:#333;padding-bottom:4px;border-bottom:1px solid #e0dbd0}
#content h3{font-size:15px;margin:14px 0 6px;color:#444}
#content blockquote{margin:8px 0;padding:5px 14px;border-left:3px solid var(--c);background:#f8f7f4;color:#666}
#content pre{background:#2d2d2d;padding:12px;border-radius:3px;overflow-x:auto;font-size:13px;line-height:1.5;margin:8px 0}
#content code{font-family:"Fira Code",Consolas,monospace;font-size:.9em}
#content :not(pre)>code{background:#f0ede5;padding:1px 3px;border-radius:2px;color:var(--c)}
#content pre code{background:transparent;padding:0;color:#ccc}
#content img{max-width:600px;max-height:400px;height:auto;width:auto;border-radius:2px;margin:6px 0}
#content table{border-collapse:collapse;width:100%;margin:8px 0;font-size:13px}
#content th,#content td{border:1px solid #ddd;padding:5px 8px}
#content th{background:#f5f2eb;font-weight:bold}
#content ul,#content ol{margin:4px 0;padding-left:22px}

/* === List Items === */
.forum-topic{padding:8px 12px;margin-bottom:6px;border:1px solid #e0dbd0;background:#fafaf5}
.forum-topic:hover{border-color:var(--c)}
.forum-topic h3{font-size:14px;margin-bottom:2px}
.forum-topic h3 a{color:#333}.forum-topic h3 a:hover{color:var(--c)}
.forum-topic.pinned{border-left:3px solid var(--c)}
.forum-meta{font-size:11px;color:#999}
.forum-cat{display:inline-block;font-size:10px;padding:1px 5px;background:#f0ede5;border-radius:2px;color:#888;margin-left:3px}

/* === Comments === */
.comment{margin-bottom:4px;padding:6px 10px;border:1px solid #e0dbd0;background:#fafaf5;font-size:13px}
.comment .cmt-header{font-size:12px;margin-bottom:2px}
.comment .cmt-header a{font-weight:bold;color:var(--c)}
.comment .cmt-body{font-size:13px;line-height:1.6}
.comment .cmt-body p{margin:3px 0}
.comment-form{margin-top:14px}
.comment-form textarea{width:100%;padding:8px;border:1px solid #ccc;border-radius:2px;font-size:13px;font-family:inherit;min-height:80px;resize:vertical}
.comment-form textarea:focus{outline:none;border-color:var(--c)}
.cmt-btn{background:var(--c);color:#fff;border:none;padding:5px 14px;border-radius:2px;cursor:pointer;font-size:12px;margin-top:4px}
.cmt-btn:hover{background:var(--cd)}

/* === Auth === */
.auth-form{max-width:400px;margin:30px auto;padding:20px;background:#fff;border:1px solid #ddd}
.auth-form h2{font-size:16px;margin-bottom:14px;text-align:center}
.auth-form label{display:block;font-size:13px;margin-bottom:2px;color:#555;font-weight:bold}
.auth-form input[type=text],.auth-form input[type=password],.auth-form input[type=email]{width:100%;padding:7px 10px;border:1px solid #ccc;font-size:13px;margin-bottom:10px;font-family:inherit}
.auth-form input:focus{outline:none;border-color:var(--c)}
.auth-form .submit-btn{width:100%;background:var(--c);color:#fff;border:none;padding:7px;font-size:14px;cursor:pointer}
.auth-form .submit-btn:hover{background:var(--cd)}
.auth-error{color:#c00;font-size:12px;text-align:center;margin-bottom:8px}

/* === Search === */
.search-page .search-box{display:flex;gap:6px;margin-bottom:12px}
.search-page .search-box input{flex:1;padding:7px 12px;border:1px solid #ccc;font-size:14px;font-family:inherit}
.search-page .search-box button{background:var(--c);color:#fff;border:none;padding:7px 16px;cursor:pointer;font-size:13px}
.search-tabs{display:flex;margin-bottom:12px;border-bottom:2px solid var(--c)}
.search-tabs a,.search-tabs span{padding:6px 14px;font-size:12px;color:#555}
.search-tabs a.active,.search-tabs a:hover{background:#f8f6f0;color:var(--c);font-weight:bold;text-decoration:none}

/* === Profile === */
.profile-header{display:flex;gap:14px;margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid #e0dbd0}
.profile-avatar{flex-shrink:0}
.profile-avatar img{width:240px !important;height:240px !important;border:3px solid #e0dbd0;border-radius:4px}
.profile-info{min-width:0;flex:1;overflow:hidden}
.profile-info h2{font-size:18px;margin-bottom:2px;border:none;padding:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.profile-info .bio{color:#666;font-size:12px;margin:2px 0}
.profile-info .meta{font-size:11px;color:#999}

/* === Admin === */
.admin-table{width:100%;border-collapse:collapse;font-size:12px;margin-bottom:12px}
.admin-table th,.admin-table td{border:1px solid #ddd;padding:4px 8px}
.admin-table th{background:#f5f2eb}
.admin-table button{background:var(--c);color:#fff;border:none;padding:2px 8px;cursor:pointer;font-size:11px}

/* === Pages === */
.pages-nav{text-align:center;margin:16px 0}
.pages-nav a,.pages-nav span{padding:3px 8px;margin:0 1px;border:1px solid #ddd;font-size:12px;display:inline-block}
.pages-nav span.current{background:var(--c);color:#fff;border-color:var(--c)}

/* === Editor === */
.editor-wrap{max-width:760px;margin:0 auto}
.editor-wrap input,.editor-wrap select,.editor-wrap textarea{width:100%;padding:7px 10px;border:1px solid #ccc;font-size:14px;font-family:inherit;margin-bottom:8px}
.editor-wrap textarea{min-height:300px;font-family:"Fira Code",Consolas,monospace;font-size:14px;line-height:1.6}
.editor-wrap label{font-weight:bold;font-size:12px;color:#555;display:block;margin-bottom:2px}
.cmt-toolbar button{background:#f0ede5;border:1px solid #ccc;cursor:pointer;padding:2px 6px;font-size:11px;color:#555}
.cmt-toolbar button:hover{background:var(--c);color:#fff;border-color:var(--c)}

/* === Notif badge === */
.notif-badge{position:absolute;top:-5px;right:-8px;background:#c00;color:#fff;border-radius:8px;padding:0 4px;font-size:9px;font-weight:bold;line-height:1.4}

@media(max-width:768px){
  #Header{flex-direction:column;padding:10px 0 0}
  #HeadLeft{padding:0 12px}
  #HeadRight{margin-top:8px;justify-content:flex-start;padding:0 12px}
  #MenuTop{margin:6px 0 0 0;padding:5px 12px}
  #MenuTop ul{gap:2px 0}
  #MenuTop li+li::before{margin:0 5px}
  #MenuTop a,#MenuTop .nav-btn{font-size:11px}
  #MainBody{flex-direction:column;padding:10px 14px}#SideBar{width:100%}
  .profile-header{flex-direction:column;gap:8px}
  .profile-info h2{font-size:16px}
}
.theme-green{--c:#5a8a5a;--cd:#4a6a4a;--cl:#8ccd8c;--cbg:#e6f7e6}
.theme-blue{--c:#5a8aaa;--cd:#4a6a8a;--cl:#8ab8e8;--cbg:#e4effa}
.theme-purple{--c:#7a6a9a;--cd:#5a4a7a;--cl:#c8a0e8;--cbg:#f3e6fc}
.theme-orange{--c:#b8845a;--cd:#8a5a3a;--cl:#e8b88a;--cbg:#fef3e6}
.theme-red{--c:#a06050;--cd:#7a4038;--cl:#e8a098;--cbg:#fce8e6}
.theme-teal{--c:#5a8a7a;--cd:#3a6a5a;--cl:#8ad0c0;--cbg:#e6f5f2}
.theme-pink{--c:#9a6a80;--cd:#7a4a60;--cl:#e8a0c0;--cbg:#fce6f0}
.theme-dark{--c:#5a7a5a;--cd:#4a5a4a;--cl:#90b898;--cbg:#e8f0e8}

/* === Poster Carousel === */
#PosterBar{height:140px;overflow:hidden;position:relative;border-bottom:1px solid #ddd;background:#1a1a1a}
#PosterTrack{display:flex;width:max-content;animation:posterScroll 60s linear infinite}
#PosterTrack img{height:140px;width:auto;display:block;flex-shrink:0}
#PosterTrack:hover{animation-play-state:paused}
@keyframes posterScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* === Lightbox === */
#lightbox{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.92);z-index:9999;cursor:zoom-out;align-items:center;justify-content:center}
#lightbox img{max-width:95vw;max-height:95vh;object-fit:contain;box-shadow:0 0 40px rgba(0,0,0,.5)}
#lightbox .lb-close{position:absolute;top:16px;right:24px;color:#fff;font-size:32px;cursor:pointer;line-height:1}
</style>
<script>window._csrf='<%= csrf %>';(function(){var m=document.cookie.match(/ntopia_theme=([^;]+)/);document.documentElement.className="theme-"+(m?m[1]:"green");})();</script>
</head>
<body>
<div id="Container">

<div id="Header">
  <div id="HeadLeft">
    <h1><a href="/">Ntopia</a></h1>
    <div id="navigation">记录思考，分享技术，探索世界</div>
  </div>
  <div id="HeadRight">
    <div id="Submissions">
      <p>欢迎访问 Ntopia！</p>
    </div>
  </div>
  <div id="MenuTop">
    <ul>
      <li><a href="/" class="<%= path === '/' ? 'nav-active' : '' %>">首页</a></li>
      <li><a href="/search" class="<%= path === '/search' ? 'nav-active' : '' %>">搜索</a></li>
      <% if (user) { %>
        <li><a href="/settings">设置</a></li>
        <li><a href="/users/<%= user.username %>">我的</a></li>
        <li><a href="/bookmarks">收藏</a></li>
        <li><a href="/drafts">草稿</a></li>
        <% if ((user.role || 0) >= LEVEL.ADMIN) { %><li><a href="/admin">管理</a></li><% } %>
        <li><a href="/notifications" style="position:relative">通知<% if (unreadNotifs) { %><span class="notif-badge"><%= unreadNotifs > 99 ? '99+' : unreadNotifs %></span><% } %></a></li>
        <li><a href="/messages" style="position:relative">私信<% if (unreadMessages) { %><span class="notif-badge"><%= unreadMessages > 99 ? '99+' : unreadMessages %></span><% } %></a></li>
        <li><a href="/rss.xml" target="_blank">RSS</a></li>
        <li><form method="POST" action="/auth/logout" style="display:inline"><input type="hidden" name="_csrf" value="<%= csrf %>"><button type="submit" class="nav-btn" style="background:none;border:none;cursor:pointer;font-family:inherit;padding:0">退出</button></form></li>
      <% } else { %>
        <li><a href="/auth/login">登录</a></li>
      <% } %>
    </ul>
  </div>
</div>

<% if (user && user.needsEmail) { %>
<div style="background:#fff3cd;color:#856404;text-align:center;padding:6px;font-size:12px;border-bottom:1px solid #ffc107">
  未绑定邮箱，无法发表内容。请前往 <a href="/settings" style="font-weight:bold;color:#856404">设置</a> 绑定或换绑邮箱。
</div>
<% } %>
<% if (user) { %>
<div id="UserBar">
  欢迎回来，<a href="/users/<%= user.username %>"><%= user.display_name || user.username %></a>
  <% var b = roleBadge(user.role || 0); %>
  <span class="lv-badge" data-level="LEVEL=<%= user.role %>" style="background:<%= b.bg %>;color:<%= b.color %>"><%= b.text %></span>
  <span class="xp-badge">Lv.<%= user.level || 1 %> (<%= user.xp || 0 %>/<%= user.xpNextTotal || 5 %> EXP)</span>
  <button class="checkin-btn" id="checkinBtn" onclick="doCheckin()">签到</button>
</div>
<% } %>

<div id="InfoBar">
  <div class="ib-block">
    <div style="display:flex;gap:20px">
      <div style="flex:1">
        <h3>关于本站</h3>
        <p>Ntopia 是由 Licphel 创建的论坛社区。请勿发布违法违规内容。
          支持 Markdown 与 LaTeX，内容遵循 CC BY-NC-SA 4.0。
          注册即可发文章、讨论、私信，签到升级。
          感谢所有参与讨论、分享知识的朋友们。欢迎通过评论或私信进行交流。</p>
      </div>
      <div style="flex:1">
        <h3>站务信息（重要）</h3>
        <div class="notice-board" style="max-height:100px;overflow-y:auto;border:1px solid #e0dbd0;background:#fff;padding:4px 8px;border-radius:3px;font-size:11px">
          <ul style="list-style:none;padding:0;margin:0">
            <% if (typeof infoPages !== 'undefined') { infoPages.forEach(function(pg) { %>
              <li style="padding:2px 0;border-bottom:1px dotted #eee"><a href="<%= pg.url %>" style="color:var(--c)"><%= pg.title %></a></li>
            <% }); } %>
          </ul>
        </div>
      </div>
    </div>
  </div>

<% if (posters && posters.length) { %>
<div id="PosterBar"><div id="PosterTrack">
  <% for (var pi = 0; pi < 2; pi++) { posters.forEach(function(p) { %>
    <img src="<%= p %>" alt="" loading="lazy">
  <% }); } %>
</div></div>
<% } %>

<div id="MainBody"<%= (typeof hideSidebar !== 'undefined' && hideSidebar) ? ' style="max-width:860px;margin:0 auto"' : '' %>>
  <div id="content"><%- body %></div>
  <% if (typeof hideSidebar === 'undefined' || !hideSidebar) { %><%- include('sidebar') %><% } %>
</div>

<div id="Footer">
  <p>&copy; 2026 Ntopia. All rights reserved. Powered by <a href="https://nodejs.org">Node.js</a> &amp; <a href="https://sqlite.org">SQLite</a>.
  <br>Content licensed under <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/">Creative Commons BY-NC-SA 4.0</a>.</p>
</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/components/prism-core.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/plugins/autoloader/prism-autoloader.min.js"></script>
<script>
(function(){
  var today = new Date().toISOString().slice(0,10);
  var saved = sessionStorage.getItem('ntopia_checkin_' + today);
  if (saved === 'done') {
    var btn = document.getElementById('checkinBtn');
    if (btn) { btn.textContent = '已签到'; btn.classList.add('done'); }
  }
})();
async function doCheckin() {
  var btn = document.getElementById('checkinBtn');
  if (!btn || btn.classList.contains('done')) return;
  try {
    btn.textContent = '签到中...';
    var resp = await fetch('/auth/checkin', { method: 'POST', headers: {'x-csrf-token':'<%= csrf %>'} });
    var data = await resp.json();
    if (data.ok) {
      btn.textContent = '已签到(' + data.total + '天) +' + data.xpEarned + 'XP';
      btn.classList.add('done');
      sessionStorage.setItem('ntopia_checkin_' + new Date().toISOString().slice(0,10), 'done');
      setTimeout(function(){ location.reload(); }, 800);
    } else if (data.already) {
      btn.textContent = '已签到(' + data.total + '天)';
      btn.classList.add('done');
      sessionStorage.setItem('ntopia_checkin_' + new Date().toISOString().slice(0,10), 'done');
    }
  } catch(e) { btn.textContent = '签到'; }
}
</script>
<script>
async function toggleLike(e, postId, commentId) {
  e.preventDefault();
  if(!<%= user ? 'true' : 'false' %>) return;
  var resp = await fetch('/likes/toggle', { method:'POST', headers:{'Content-Type':'application/json','x-csrf-token':'<%= csrf %>'}, body:JSON.stringify({post_id:postId||null, comment_id:commentId||null}) });
  var d = await resp.json();
  var elId = 'like-' + (postId ? 'post-' + postId : 'comment-' + commentId);
  var el = document.getElementById(elId);
  if(el) el.textContent = (d.liked ? '已赞' : '点赞') + (d.count ? ' (' + d.count + ')' : '');
}
async function toggleBookmark(e, postId) {
  e.preventDefault();
  if(!<%= user ? 'true' : 'false' %>) return;
  var resp = await fetch('/bookmarks/toggle', { method:'POST', headers:{'Content-Type':'application/json','x-csrf-token':'<%= csrf %>'}, body:JSON.stringify({post_id:postId}) });
  var d = await resp.json();
  var el = document.getElementById('bookmark-' + postId);
  if(el) el.textContent = d.bookmarked ? '已收藏' : '收藏';
}
</script>

<div id="lightbox" onclick="this.style.display='none'"><span class="lb-close">&times;</span><img id="lightbox-img" src=""></div>
<script>
(function(){
  var lb=document.getElementById('lightbox');
  var lbImg=document.getElementById('lightbox-img');
  document.addEventListener('click',function(e){
    var t=e.target;
    if(t.tagName==='IMG'&&t.closest('.PostContent')){
      lb.style.display='flex';lbImg.src=t.src;
    }
  });
  document.addEventListener('keydown',function(e){if(e.key==='Escape')lb.style.display='none';});
})();
</script>

<script>
// Preserve scroll position across page reloads
(function(){
  var key = 'ntopia_scroll_' + location.pathname;
  var saved = sessionStorage.getItem(key);
  if (saved) {
    // Restore on next paint after images/embeds settle
    var y = parseInt(saved, 10);
    if (y > 0) {
      var restore = function() {
        window.scrollTo(0, y);
        if (Math.abs(window.scrollY - y) > 50) {
          requestAnimationFrame(function() { window.scrollTo(0, y); });
        }
      };
      requestAnimationFrame(restore);
      setTimeout(restore, 200);
    }
    sessionStorage.removeItem(key);
  }
  // Save scroll on navigation and periodically
  var save = function() { sessionStorage.setItem(key, window.scrollY); };
  var ticking = false;
  window.addEventListener('scroll', function() {
    if (!ticking) { requestAnimationFrame(function() { save(); ticking = false; }); ticking = true; }
  }, { passive: true });
  window.addEventListener('beforeunload', save);
})();
</script>

