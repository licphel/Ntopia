<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
  <h2 style="margin:0;padding:0;border:none">私信</h2>
  <a href="/messages/send" style="background:var(--c);color:#fff;padding:5px 14px;border-radius:3px;font-size:13px;text-decoration:none">+ 发私信</a>
</div>

<h3>收件箱</h3>
<% if (msgs.length === 0) { %><p style="color:#999">暂无私信。</p><% } %>
<% msgs.forEach(function(m) { %>
<div class="comment" style="<%= m.is_read ? '' : 'border-left:3px solid var(--c);background:#f8fff8' %>">
  <div class="cmt-header">
    <a href="/users/<%= m.username %>"><strong><%= m.display_name || m.username %></strong></a>
    <span style="color:#999;font-size:11px"><%= m.created_at.slice(0, 16) %></span>
    <a href="/messages/send/<%= m.username %>" style="font-size:11px;margin-left:8px">回复</a>
  </div>
  <div class="cmt-body"><%- m.content_html %></div>
</div>
<% }); %>

<%- include('pagination', { page: msgPage, totalPages: msgTotalPages, baseUrl: '/messages', param: 'page' }) %>

<h3 style="margin-top:24px">已发送</h3>
<% if (sent.length === 0) { %><p style="color:#999">暂无发送记录。</p><% } %>
<% sent.forEach(function(m) { %>
<div class="comment">
  <div class="cmt-header">
    发给 <a href="/users/<%= m.username %>"><strong><%= m.display_name || m.username %></strong></a>
    <span style="color:#999;font-size:11px"><%= m.created_at.slice(0, 16) %></span>
  </div>
  <div class="cmt-body"><%- m.content_html %></div>
</div>
<% }); %>

<%- include('pagination', { page: sentPage, totalPages: sentTotalPages, baseUrl: '/messages', param: 'sp' }) %>
