<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
  <h2 style="margin:0;padding:0;border:none">论坛</h2>
  <% if (user) { %>
    <a href="/forum/new-topic" style="background:var(--c);color:#fff;padding:6px 14px;border-radius:3px;font-size:13px;text-decoration:none">+ 发布新主题</a>
  <% } %>
</div>

<!-- Category tabs -->
<div class="search-tabs" style="margin-bottom:8px">
  <a href="/forum<%= sort ? '?sort='+sort : '' %>" class="<%= !currentCat ? 'active' : '' %>">全部</a>
  <% categories.forEach(function(cat) { %>
    <a href="/forum?cat=<%= cat.slug %>&sort=<%= sort || 'newest' %>" class="<%= currentCat === cat.slug ? 'active' : '' %>"><%= cat.name %></a>
  <% }); %>
</div>

<!-- Sort tabs -->
<div style="display:flex;gap:0;font-size:12px;margin-bottom:12px">
  <% var base = '/forum' + (currentCat ? '?cat=' + currentCat + '&' : '?'); %>
  <a href="<%= base %>sort=newest" style="padding:3px 10px;border:1px solid #ccc;<%= (sort||'newest')==='newest'?'background:var(--c);color:#fff;':'' %>">最新</a>
  <a href="<%= base %>sort=replies" style="padding:3px 10px;border:1px solid #ccc;border-left:none;<%= sort==='replies'?'background:var(--c);color:#fff;':'' %>">回复</a>
  <a href="<%= base %>sort=hot" style="padding:3px 10px;border:1px solid #ccc;border-left:none;<%= sort==='hot'?'background:var(--c);color:#fff;':'' %>">热门</a>
</div>

<% if (topics.length === 0) { %>
  <p style="color:#999;text-align:center;padding:40px 0">该分类下还没有主题。</p>
<% } %>

<% topics.forEach(function(t) { %>
<div class="forum-topic <%= t.is_pinned ? 'pinned' : '' %>">
  <div style="display:flex;justify-content:space-between;align-items:flex-start">
    <div style="flex:1">
      <h3>
        <% if (t.is_pinned) { %><span style="color:var(--c)">[置顶]</span><% } %>
        <a href="/forum/<%= t.slug %>"><%= t.title %></a>
        <% if (t.forum_category) { %><span class="forum-cat"><%= t.category_name || t.forum_category %></span><% } %>
      </h3>
      <div class="forum-meta">
        <img src="<%= t.avatar || '/img/default-avatar.svg' %>" style="width:18px;height:18px;vertical-align:middle;margin-right:3px"><a href="/users/<%= t.username %>"><%= t.display_name || t.username %></a> |
        <%= t.created_at.slice(0, 10) %> |
        <%= t.comment_count %> 回复 |
        <%= t.view_count %> 浏览
      </div>
    </div>
    <div style="text-align:right;font-size:11px;color:#999;white-space:nowrap;margin-left:10px">
      <div><%= t.comment_count %></div>
      <div>回复</div>
    </div>
  </div>
</div>
<% }); %>

<% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
<div class="pages-nav">
  <% for (var i = 1; i <= totalPages; i++) { %>
    <% if (i === page) { %>
      <span class="current"><%= i %></span>
    <% } else { %>
      <a href="/forum?sort=<%= sort || 'newest' %>&<%= currentCat ? 'cat=' + currentCat + '&' : '' %>page=<%= i %>"><%= i %></a>
    <% } %>
  <% } %>
</div>
<% } %>
