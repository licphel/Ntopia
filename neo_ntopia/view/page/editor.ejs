<style>
/* Side-by-side editor preview */
.ed-split{display:flex;gap:0;margin-bottom:8px}
.ed-split .ed-left{flex:1;min-width:0}
.ed-split .ed-left textarea{min-height:400px;resize:vertical}
.ed-split .ed-right{flex:1;min-width:0;overflow-y:auto;border:1px solid #ccc;border-left:none;padding:10px 14px;background:#fafaf5;font-size:13px;line-height:1.7}
.ed-split .ed-right h2{font-size:17px !important;margin:6px 0 8px !important;padding-bottom:3px !important;border-bottom:1px solid #e0dbd0 !important}
.ed-split .ed-right h3{font-size:14px !important;margin:10px 0 4px !important}
.ed-split .ed-right p{margin:4px 0}
.ed-split .ed-right pre{background:#2d2d2d;color:#ccc;padding:10px;overflow-x:auto;font-size:12px;border-radius:3px}
.ed-split .ed-right code{font-family:"Fira Code",Consolas,monospace;font-size:.9em}
.ed-split .ed-right blockquote{border-left:3px solid var(--c);padding:3px 10px;margin:6px 0;color:#666;background:#f8f7f4}
.ed-split .ed-right img{max-width:100%}
.ed-split .ed-right table{border-collapse:collapse;width:100%;margin:6px 0}
.ed-split .ed-right th,.ed-split .ed-right td{border:1px solid #ddd;padding:3px 6px}
.ed-split .ed-right ul,.ed-split .ed-right ol{padding-left:20px}
.ed-gutter{width:8px;cursor:col-resize;background:#e0dbd0;flex-shrink:0;transition:background .2s}
.ed-gutter:hover,.ed-gutter.active{background:var(--c)}
.ed-preview-empty{color:#999;font-style:italic;text-align:center;padding:40px 0}
@media(max-width:768px){.ed-split{flex-direction:column}.ed-split .ed-right{border-left:1px solid #ccc;border-top:none;min-height:200px}.ed-gutter{width:100%;height:6px;cursor:row-resize}}
</style>

<div class="editor-wrap">
  <h2><%= post ? '编辑' : '发帖' %><% if (typeof sectionName !== 'undefined') { %> 到 <a href="/forum/<%= presetCategory %>" style="color:var(--c)"><%= sectionName %></a><% } %></h2>

  <% if (typeof canPost !== 'undefined' && !canPost) { %>
    <p style="color:#c00;margin-bottom:12px">每天只能发布一篇帖子，你今天已经发布过了。</p>
  <% } else { %>

  <form method="POST" action="<%= post ? '/posts/' + post.id + '/edit' : '/new-post' %>">
  <input type="hidden" name="_csrf" value="<%= csrf %>">

    <label>标题</label>
    <input type="text" name="title" value="<%= post ? post.title : '' %>" required>

    <input type="hidden" name="category" value="<%= typeof presetCategory !== 'undefined' ? presetCategory : (post ? post.category_id : '') %>">
    <% if (typeof subCategories !== 'undefined' && subCategories.length) { %>
    <div style="margin-bottom:8px">
      <label>分类</label>
      <select name="sub_category" style="width:auto;min-width:120px">
        <option value="-1">默认</option>
        <% subCategories.forEach(function(sc){ %>
        <option value="<%= sc.name %>" <%= (typeof presetSubCategory !== 'undefined' && presetSubCategory === sc.name) || (post && post.sub_category === sc.name) ? 'selected' : '' %>><%= sc.name %></option>
        <% }); %>
      </select>
    </div>
    <% } else { %>
    <input type="hidden" name="sub_category" value="<%= typeof presetSubCategory !== 'undefined' ? presetSubCategory : (post && post.sub_category ? post.sub_category : '-1') %>">
    <% } %>

    <label>正文（Markdown 格式，支持 $...$ 数学公式）</label>
    <%- include('widget/comment-toolbar') %>
    <div class="ed-split" id="edSplit">
      <div class="ed-left" id="edLeft">
        <textarea name="content" id="edContent"><%= post ? post.content_md : '' %></textarea>
      </div>
      <div class="ed-gutter" id="edGutter"></div>
      <div class="ed-right" id="edPreview"><div class="ed-preview-empty">输入内容后自动预览...</div></div>
    </div>

    <input type="hidden" name="is_draft" value="0" id="is-draft-field">
    <button type="submit" class="cmt-btn" style="padding:10px 24px;font-size:15px;margin-top:8px">发布</button>
    <button type="button" class="cmt-btn" onclick="document.getElementById('is-draft-field').value='1';this.form.submit()" style="padding:10px 24px;font-size:15px;background:#999;margin-top:8px">保存草稿</button>
  </form>

  <% } %>
</div>

<input type="file" accept=".md,.markdown,.txt,text/markdown,text/plain" style="display:none" id="mdFileInput" onchange="importMdFile(this)">

<script>
(function(){
  var ta = document.getElementById('edContent');
  var preview = document.getElementById('edPreview');
  var timer = null;
  var lastVal = '';

  function renderTex(){
    if (window.renderMathInElement) {
      try { renderMathInElement(preview, {delimiters:[{left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false}], throwOnError: false}); } catch(_) {}
    }
  }

  function update(){
    var val = ta.value;
    if (val === lastVal) return;
    lastVal = val;
    if (!val.trim()) { preview.innerHTML = '<div class="ed-preview-empty">输入内容后自动预览...</div>'; return; }
    preview.innerHTML = '<div class="ed-preview-empty">渲染中...</div>';
    fetch('/preview', {
      method: 'POST',
      headers: {'Content-Type':'application/json','x-csrf-token':'<%= csrf %>'},
      body: JSON.stringify({content: val})
    }).then(function(r){ return r.json(); }).then(function(d){
      if (d.html) { preview.innerHTML = d.html; renderTex(); }
    }).catch(function(){ preview.innerHTML = '<div class="ed-preview-empty" style="color:#c00">预览失败</div>'; });
  }

  ta.addEventListener('input', function(){
    clearTimeout(timer);
    timer = setTimeout(update, 300);
  });

  // Initial preview if editing existing post
  if (ta.value.trim()) update();

  // Sync preview height with textarea
  function syncHeight(){
    preview.style.maxHeight = ta.offsetHeight + 'px';
  }
  new ResizeObserver(syncHeight).observe(ta);
  syncHeight();

  // ── Draggable gutter ──────────────────────────────────────────
  var gutter = document.getElementById('edGutter');
  var left = document.getElementById('edLeft');
  var right = preview;
  var dragging = false;

  gutter.addEventListener('mousedown', function(e){
    e.preventDefault();
    dragging = true;
    gutter.classList.add('active');
    document.body.style.cursor = 'col-resize';
    document.body.style.userSelect = 'none';
  });

  document.addEventListener('mousemove', function(e){
    if (!dragging) return;
    var rect = document.getElementById('edSplit').getBoundingClientRect();
    var x = e.clientX - rect.left;
    var total = rect.width - 8;
    var pct = Math.max(20, Math.min(80, x / total * 100));
    left.style.flex = pct;
    right.style.flex = (100 - pct);
  });

  document.addEventListener('mouseup', function(){
    if (!dragging) return;
    dragging = false;
    gutter.classList.remove('active');
    document.body.style.cursor = '';
    document.body.style.userSelect = '';
  });
})();

// ── MD file import ─────────────────────────────────────────────
function importMdFile(inp){
  var file = inp.files[0];
  if (!file) return;
  var reader = new FileReader();
  reader.onload = async function(e){
    var ta = document.getElementById('edContent');
    var text = e.target.result;
    if (ta.value.trim()) {
      var ok = await ntopiaConfirm('当前编辑区已有内容，导入 .md 文件将替换现有内容。是否继续？');
      if (!ok) { inp.value = ''; return; }
    }
    ta.value = text;
    ta.dispatchEvent(new Event('input', {bubbles:true}));
    ta.focus();
  };
  reader.readAsText(file);
  inp.value = '';
}
</script>
