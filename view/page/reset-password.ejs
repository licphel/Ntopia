<div class="auth-form">
  <h2>重置密码</h2>
  <% if (ok) { %>
    <div style="color:var(--c);text-align:center;margin-bottom:10px;font-size:14px"><%= ok %></div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="auth-error"><%= error %></div>
  <% } %>
  <form method="POST" action="/auth/reset-password/reset">
  <input type="hidden" name="_csrf" value="<%= csrf %>">
    <label>注册邮箱</label>
    <div style="display:flex;gap:8px;margin-bottom:10px">
      <input type="email" name="email" required placeholder="输入注册时使用的邮箱" style="flex:1;margin-bottom:0">
      <button type="button" id="sendBtn" onclick="sendResetCode()" style="background:var(--btn-accent-bg);color:var(--text-inverse);border:none;padding:7px 14px;border-radius:var(--radius);cursor:pointer;font-size:12px;white-space:nowrap">发送验证码</button>
      <span id="sendStatus" style="font-size:11px;color:var(--text-muted)"></span>
    </div>
    <label>验证码</label>
    <input type="text" name="code" required placeholder="邮箱收到的6位验证码">
    <label>新密码</label>
    <input type="password" name="new_password" required placeholder="至少4个字符">
    <label>确认新密码</label>
    <input type="password" name="new_password2" required>
    <button type="submit" class="submit-btn">重置密码</button>
  </form>
  <p style="text-align:center;margin-top:12px;font-size:13px"><a href="/auth/login">返回登录</a></p>
</div>

<script>
var cd = 0;
function sendResetCode(){
  if (cd > 0) return;
  var em = document.querySelector('[name=email]').value;
  if (!em.includes('@')){ document.getElementById('sendStatus').textContent='邮箱格式错误'; return; }
  var btn = document.getElementById('sendBtn');
  btn.textContent='发送中...'; btn.disabled=true;
  document.getElementById('sendStatus').textContent='';
  fetch('/email/send',{method:'POST',headers:{'Content-Type':'application/json','x-csrf-token':(window._csrf||'')},body:JSON.stringify({email:em})})
    .then(r=>r.json()).then(d=>{
      if(d.ok){ cd=60; document.getElementById('sendStatus').textContent='已发送'; tickBtn(btn); }
      else { btn.textContent='发送验证码'; btn.disabled=false; document.getElementById('sendStatus').textContent=d.error||'失败'; }
    }).catch(function(){ btn.textContent='发送验证码'; btn.disabled=false; document.getElementById('sendStatus').textContent='网络错误'; });
}
function tickBtn(btn){
  if(cd<=0){ btn.textContent='发送验证码'; btn.disabled=false; document.getElementById('sendStatus').textContent=''; return; }
  btn.textContent=cd+'s后重发'; cd--; setTimeout(function(){tickBtn(btn)},1000);
}
</script>
