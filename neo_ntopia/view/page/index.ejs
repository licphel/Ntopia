<% if (typeof section !== 'undefined') { %>
<div style="background:#fafaf5;border:1px solid #e0dbd0;border-radius:6px;padding:14px 16px;margin-bottom:12px;display:flex;gap:14px;align-items:center">
  <% if (section.image) { %><img src="<%= section.image %>" style="width:64px;height:64px;border-radius:6px;object-fit:cover;border:2px solid #e0dbd0;flex-shrink:0"><% } else { %><div style="width:64px;height:64px;border-radius:6px;background:#e0dbd0;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:24px;color:#999"><%= (section.name||'?')[0] %></div><% } %>
  <div style="flex:1;min-width:0">
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
      <h2 style="margin:0;padding:0;border:none;font-size:18px"><%= section.name %></h2>
      <% if (user) { %><button onclick="toggleSectionFollow(event,'<%= section.id %>')" id="sf-btn-<%= section.id %>" style="background:none;border:1px solid #ccc;border-radius:3px;cursor:pointer;font-size:11px;padding:2px 8px;white-space:nowrap"><%= (typeof sectionFollowed !== 'undefined' && sectionFollowed) ? '已关注' : '关注' %></button><% } %>
      <% if (typeof isSectionMod !== 'undefined' && isSectionMod) { %><a href="/forum/<%= section.id %>/settings" style="font-size:11px;color:var(--c);margin-left:4px;white-space:nowrap">设置</a><% } %>
    </div>
    <% if (section.description) { %><div style="font-size:13px;color:#666"><%= section.description %></div><% } %>
    <div style="font-size:11px;color:#999;margin-top:2px"><span id="sf-count-<%= section.id %>"><%= typeof followerCount !== 'undefined' ? followerCount : 0 %></span> 人关注</div>
  </div>
</div>
<% } %>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
  <h2 style="margin:0;padding:0;border:none"><%= typeof section !== 'undefined' ? '' : '论坛' %></h2>
  <% if (user) { %>
    <a href="/new-post<%= (typeof section !== 'undefined' && section) ? '?cat=' + section.id : '' %>"
      style="background:var(--c);color:#fff;padding:6px 14px;border-radius:3px;font-size:13px;text-decoration:none">+
      发帖</a>
    <% } %>
</div>

<% if (typeof subCategories !== 'undefined' && subCategories.length) { %>
<div class="search-tabs" style="margin-bottom:8px">
  <a href="/forum/<%= section.id %>?sort=<%= sort || 'newest' %>" class="<%= !subCat ? 'active' : '' %>">全部(<%= typeof total !== 'undefined' ? total : 0 %>)</a>
  <% subCategories.forEach(function(sc){ %>
    <a href="/forum/<%= section.id %>?sub=<%= encodeURIComponent(sc.name) %>&sort=<%= sort || 'newest' %>" class="<%= subCat === sc.name ? 'active' : '' %>"><%= sc.name %>(<%= sc.post_count || 0 %>)</a>
  <% }); %>
</div>
<% } %>

<div style="display:flex;gap:0;font-size:12px;margin-bottom:12px">
  <% var base=typeof section !== 'undefined' ? '/forum/' + section.id + '?' + (subCat ? 'sub=' + encodeURIComponent(subCat) + '&' : '') : '?'; %>
    <a href="<%= base %>sort=newest"
      style="padding:3px 10px;border:1px solid #ccc;<%= (sort||'newest')==='newest'?'background:var(--c);color:#fff;':'' %>">最新</a>
    <a href="<%= base %>sort=replies"
      style="padding:3px 10px;border:1px solid #ccc;border-left:none;<%= sort==='replies'?'background:var(--c);color:#fff;':'' %>">回复</a>
    <a href="<%= base %>sort=hot"
      style="padding:3px 10px;border:1px solid #ccc;border-left:none;<%= sort==='hot'?'background:var(--c);color:#fff;':'' %>">热门</a>
  <% if (typeof section !== 'undefined') { %>
  <label style="margin-left:12px;font-size:12px;display:flex;align-items:center;gap:4px;cursor:pointer">
    <input type="checkbox" onchange="location.href='/forum/<%= section.id %>?sort=<%= sort %>&featured='+(this.checked?'1':'0')" <%= featured ? 'checked' : '' %>> 只看精华
  </label>
  <% } %>
</div>

<% if (posts.length===0) { %>
  <p style="color:#999;text-align:center;padding:40px 0">还没有帖子。</p>
  <% } %>

    <% posts.forEach(function(post) { %>
      <div class="Post<%= post.is_pinned ? ' pinned' : '' %>" style="position:relative">
        <% if (post.is_featured) { %><span style="position:absolute;top:0;right:-2px;z-index:1;pointer-events:none;font-size:11px;font-weight:bold;background:linear-gradient(135deg,#f90,#f60);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;text-shadow:none;transform:rotate(8deg)">精华</span><% } %>
        <div class="PostHead">
          <div class="date-col">
            <div class="date-wrap<%= post.is_pinned ? ' forum-date' : '' %>">
              <span class="date-day">
                <%- timeTag(post.created_at, {fmt:'day'}) %>
              </span>
              <span class="date-month">
                <%- timeTag(post.created_at, {fmt:'month'}) %>
              </span>
            </div>
            <div class="date-cat"><%- timeTag(post.created_at, {fmt:'year'}) %></div>
          </div>
          <div class="title-wrap">
            <h2><a href="/posts/<%= post.id %>">
                <%= post.title %>
              </a></h2>
            <span class="submitted">
              <img src="<%= post.avatar || '/img/default-avatar.png' %>"
                style="width:18px;height:18px;vertical-align:middle;margin-right:3px"><a
                href="/users/<%= post.author_id %>">
                <%= post.display_name || post.username %>
              </a>
              <span class="lv-badge">Lv.<%= post.level || 1 %></span> |
              <%- timeTag(post.created_at) %>
                | <%= post.comment_count %> 评论 | <%= post.view_count %> 阅读
            </span>
          </div>
        </div>
        <div class="PostContent">
          <%- post.preview_html || '' %>
            <% if (post.content_html.length > (post.preview_html || '').length + 10) { %>
              <p><a href="/posts/<%= post.id %>">阅读全文...</a></p>
              <% } %>
        </div>
      </div>
      <% }); %>

        <% if (totalPages > 1) { %><%- include("pagination", { page: page, totalPages: totalPages, baseUrl: (typeof section !== 'undefined' ? '/forum/' + section.id : '/forum'), param: "page" }) %><% } %>