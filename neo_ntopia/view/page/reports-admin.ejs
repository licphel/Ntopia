<h2>举报管理</h2>

<% if (reports.length === 0) { %><p style="color:#999;padding:40px 0;text-align:center">暂无举报。</p><% } %>

<% reports.forEach(function(r) { %>
<div class="comment" style="<%= r.status === 'pending' ? 'border-left:3px solid #c00' : 'opacity:0.6' %>">
  <div style="margin-bottom:4px">
    <strong><%= r.reporter_display || r.reporter_name %></strong>
    <span style="color:#999;font-size:11px">举报了<%= r.type === 'post' ? '文章' : '评论' %></span>
    <a href="<%= r.link %>" style="color:var(--c)"><%= r.title %></a>
    <span style="float:right;font-size:11px;color:#999"><%- timeTag(r.created_at) %>
      <% if (r.status !== 'pending') { %>
        · <%= r.status === 'resolved' ? '已处理' : '已驳回' %>
        <% if (r.resolved_by) { %>· by #<%= r.resolved_by %><% } %>
      <% } %>
    </span>
  </div>
  <% if (r.reason) { %><div style="font-size:12px;color:#666;margin-bottom:6px">原因：<%= r.reason %></div><% } %>
  <% if (r.status === 'pending') { %>
  <div style="margin-top:4px;display:flex;gap:6px">
    <form method="POST" action="/report/resolve/<%= r.id %>" style="display:inline">
      <input type="hidden" name="_csrf" value="<%= csrf %>">
      <input type="hidden" name="action" value="resolved">
      <button style="background:var(--c);color:#fff;border:none;padding:2px 8px;cursor:pointer;font-size:11px;border-radius:2px">处理</button>
    </form>
    <form method="POST" action="/report/resolve/<%= r.id %>" style="display:inline">
      <input type="hidden" name="_csrf" value="<%= csrf %>">
      <input type="hidden" name="action" value="dismissed">
      <button style="background:#999;color:#fff;border:none;padding:2px 8px;cursor:pointer;font-size:11px;border-radius:2px">驳回</button>
    </form>
  </div>
  <% } %>
</div>
<% }); %>

<%- include('pagination', { page: page, totalPages: totalPages, baseUrl: '/report/admin', param: 'page' }) %>
