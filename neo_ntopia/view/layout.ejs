  <script>
    (function () {
      var btn = document.getElementById('checkinBtn');
      if (!btn) return;
      // Query server for today's check-in status
      fetch('/auth/checkin-status', { credentials: 'same-origin' })
        .then(function (r) { return r.json(); }).then(function (d) {
          if (d.checkedIn) {
            btn.textContent = '已签到(' + d.total + '天)';
            btn.classList.add('done');
          }
        }).catch(function () { });
    })();
    async function doCheckin() {
      var btn = document.getElementById('checkinBtn');
      if (!btn || btn.classList.contains('done')) return;
      try {
        btn.textContent = '签到中...';
        var resp = await fetch('/auth/checkin', { method: 'POST', headers: { 'x-csrf-token': '<%= csrf %>' } });
        var data = await resp.json();
        if (data.ok) {
          btn.textContent = '已签到(' + data.total + '天) +' + data.xpEarned + 'XP';
          btn.classList.add('done');
          setTimeout(function () { location.reload(); }, 800);
        } else if (data.already) {
          btn.textContent = '已签到(' + data.total + '天)';
          btn.classList.add('done');
        }
      } catch (e) { btn.textContent = '签到'; }
    }
  </script>
  <script>
    async function submitReport(type, targetId) {
      if (!<%= user ? 'true' : 'false' %>) return;
      var reason = await ntopiaPrompt('举报原因（可选）：');
      if (reason === null) return;
      var r = await fetch('/report/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'x-csrf-token': window._csrf || '' },
        body: JSON.stringify({ type: type, target_id: targetId, reason: reason || '' })
      });
      var d = await r.json();
      ntopiaAlert(d.ok ? '举报已提交，管理员会尽快处理。' : (d.error || '举报失败'));
    }
    async function toggleFollow(btn, username) {
      if (!<%= user ? 'true' : 'false' %>) return;
      var r = await fetch('/follow/' + username, { method: 'POST', headers: { 'x-csrf-token': window._csrf || '' } });
      var d = await r.json();
      if (d.ok) {
        btn.textContent = d.following ? '已关注' : '+ 关注';
        var el = document.getElementById('followerCount');
        if (el) { var n = parseInt(el.textContent) || 0; el.textContent = d.following ? n + 1 : Math.max(0, n - 1); }
      }
    }
    async function toggleLike(e, postId, commentId) {
      e.preventDefault();
      if (!<%= user ? 'true' : 'false' %>) return;
      var resp = await fetch('/likes/toggle', { method: 'POST', headers: { 'Content-Type': 'application/json', 'x-csrf-token': '<%= csrf %>' }, body: JSON.stringify({ post_id: postId || null, comment_id: commentId || null }) });
      var d = await resp.json();
      var elId = 'like-' + (postId ? 'post-' + postId : 'comment-' + commentId);
      var el = document.getElementById(elId);
      if (el) { el.textContent = (d.liked ? '已赞' : '点赞') + (d.count ? '(' + d.count + ')' : ''); el.style.color = d.liked ? '' : '#999'; }
    }
    async function toggleBookmark(e, postId) {
      e.preventDefault();
      if (!<%= user ? 'true' : 'false' %>) return;
      var resp = await fetch('/bookmarks/toggle', { method: 'POST', headers: { 'Content-Type': 'application/json', 'x-csrf-token': '<%= csrf %>' }, body: JSON.stringify({ post_id: postId }) });
      var d = await resp.json();
      var el = document.getElementById('bookmark-' + postId);
      if (el) { el.textContent = (d.bookmarked ? '已收藏' : '收藏') + (d.count ? '(' + d.count + ')' : ''); el.style.color = d.bookmarked ? '' : '#999'; }
    }
    async function toggleSectionFollow(e, sectionId) {
      e.preventDefault();
      if (!<%= user ? 'true' : 'false' %>) return;
      var resp = await fetch('/forum/' + sectionId + '/follow', { method: 'POST', headers: { 'Content-Type': 'application/json', 'x-csrf-token': '<%= csrf %>' }, body: JSON.stringify({}) });
      var d = await resp.json();
      if (!d.ok) return;
      var btn = document.getElementById('sf-btn-' + sectionId);
      var cnt = document.getElementById('sf-count-' + sectionId);
      if (btn) btn.textContent = d.following ? '已关注' : '关注';
      if (cnt) cnt.textContent = d.count;
    }
  </script>

