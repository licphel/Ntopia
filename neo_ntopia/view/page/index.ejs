<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
  <h2 style="margin:0;padding:0;border:none"><%= typeof section !== 'undefined' ? section.name : (typeof isForum !== 'undefined' && isForum ? '论坛' : '文章') %></h2>
  <% if (user) { %>
    <a href="/new-post<%= (typeof section !== 'undefined' && section) ? '?cat=' + section.slug : (typeof isForum !== 'undefined' && isForum ? '?cat=forum' : '') %>"
      style="background:var(--c);color:#fff;padding:6px 14px;border-radius:3px;font-size:13px;text-decoration:none">+
      发布新文章</a>
    <% } %>
</div>
<% var basePath = (typeof isForum !== 'undefined' && isForum) ? '/forum' : '/blog'; %>
<!-- Category tabs (blog only) -->
<% if (typeof isForum === 'undefined' || !isForum) { %>
<div class="search-tabs" style="margin-bottom:8px">
  <a href="<%= basePath %>?sort=<%= sort || 'newest' %>" class="<%= !currentCat ? 'active' : '' %>">全部</a>
  <% categories.forEach(function(cat) { if (cat.slug === 'forum') return; %>
    <a href="<%= basePath %>?cat=<%= cat.slug %>&sort=<%= sort || 'newest' %>" class="<%= currentCat === cat.slug ? 'active' : '' %>">
      <%= cat.name %>
    </a>
    <% }); %>
</div>
<% } %>

<div style="display:flex;gap:0;font-size:12px;margin-bottom:12px">
  <% var currentCat = typeof currentCat !== 'undefined' ? currentCat : ''; %>
  <% var base=basePath + '?' + (currentCat ? 'cat=' + currentCat + '&' : '' ); %>
    <a href="<%= base %>sort=newest"
      style="padding:3px 10px;border:1px solid #ccc;<%= (sort||'newest')==='newest'?'background:var(--c);color:#fff;':'' %>">最新</a>
    <a href="<%= base %>sort=replies"
      style="padding:3px 10px;border:1px solid #ccc;border-left:none;<%= sort==='replies'?'background:var(--c);color:#fff;':'' %>">回复</a>
    <a href="<%= base %>sort=hot"
      style="padding:3px 10px;border:1px solid #ccc;border-left:none;<%= sort==='hot'?'background:var(--c);color:#fff;':'' %>">热门</a>
</div>

<% if (posts.length===0) { %>
  <p style="color:#999;text-align:center;padding:40px 0">还没有文章。</p>
  <% } %>

    <% posts.forEach(function(post) { %>
      <div class="Post<%= post.is_pinned ? ' pinned' : '' %>">
        <div class="PostHead">
          <div class="date-col">
            <div class="date-wrap<%= post.is_pinned ? ' forum-date' : '' %>">
              <span class="date-day">
                <%- timeTag(post.created_at, {fmt:'day'}) %>
              </span>
              <span class="date-month">
                <%- timeTag(post.created_at, {fmt:'month'}) %>
              </span>
            </div>
            <div class="date-cat"><%= post.category_name || post.category || '·' %></div>
          </div>
          <div class="title-wrap">
            <h2><a href="/posts/<%= post.slug %>">
                <%= post.title %>
              </a></h2>
            <span class="submitted">
              <img src="<%= post.avatar || '/img/default-avatar.png' %>"
                style="width:18px;height:18px;vertical-align:middle;margin-right:3px"><a
                href="/users/<%= post.username %>">
                <%= post.display_name || post.username %>
              </a>
              <span class="lv-badge">Lv.<%= post.level || 1 %></span> |
              <%- timeTag(post.created_at) %>
                <% if (post.category) { %> | <a href="/search?q=<%= encodeURIComponent(post.category) %>">
                    <%= post.category_name || post.category %>
                  </a>
                  <% } %>
                    | <%= post.comment_count %> 评论 | <%= post.view_count %> 阅读
            </span>
          </div>
        </div>
        <div class="PostContent">
          <%- post.preview_html || '' %>
            <% if (post.content_html.length > (post.preview_html || '').length + 10) { %>
              <p><a href="/posts/<%= post.slug %>">阅读全文...</a></p>
              <% } %>
        </div>
        <% if (post.tags) { %>
          <div class="tools">
            标签: <% post.tags.split(',').forEach(function(t) { %>
              <a href="/tags/<%= encodeURIComponent(t.trim()) %>">
                <%= t.trim() %>
              </a>
              <% }); %>
          </div>
          <% } %>
      </div>
      <% }); %>

        <% if (totalPages > 1) { %><%- include("pagination", { page: page, totalPages: totalPages, baseUrl: "/?sort=" + (sort||"newest"), param: "page" }) %><% } %>