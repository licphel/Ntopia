<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
  <h2 style="margin:0;padding:0;border:none">私信</h2>
  <a href="/messages/send" style="background:var(--btn-accent-bg);color:var(--text-inverse);padding:5px 14px;border-radius:var(--radius);font-size:13px;text-decoration:none">+ 发私信</a>
</div>

<h3>收件箱</h3>
<% if (msgs.length === 0) { %><p style="color:var(--text-muted)">暂无私信。</p><% } %>
<% msgs.forEach(function(m) { %>
<div class="comment" style="<%= m.is_read ? '' : 'border-left:3px solid var(--c);background:var(--bg-card)' %>">
  <div class="cmt-header">
    <%- include('widget/user-name', { u: m, showLevel: false }) %>
    <span style="color:var(--text-muted);font-size:11px"><%- timeTag(m.created_at) %></span>
    <a href="/messages/send/<%= m.from_id %>" style="font-size:11px;margin-left:8px">回复</a>
  </div>
  <div class="cmt-body"><%- m.content_html %></div>
</div>
<% }); %>

<%- include('widget/pagination', { page: msgPage, totalPages: msgTotalPages, baseUrl: '/messages', param: 'page' }) %>

<h3 style="margin-top:24px">已发送</h3>
<% if (sent.length === 0) { %><p style="color:var(--text-muted)">暂无发送记录。</p><% } %>
<% sent.forEach(function(m) { %>
<div class="comment">
  <div class="cmt-header">
    发给 <%- include('widget/user-name', { u: m, showLevel: false }) %>
    <span style="color:var(--text-muted);font-size:11px"><%- timeTag(m.created_at) %></span>
  </div>
  <div class="cmt-body"><%- m.content_html %></div>
</div>
<% }); %>

<%- include('widget/pagination', { page: sentPage, totalPages: sentTotalPages, baseUrl: '/messages', param: 'sp' }) %>
