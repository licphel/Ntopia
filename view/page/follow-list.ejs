<h2 style="font-size:16px"><%- include('widget/user-name', { u: profile }) %> 的<%= listType === 'followers' ? '粉丝' : '关注' %></h2>

<% if (users.length === 0) { %>
  <p style="color:var(--text-muted);text-align:center;padding:40px 0">空空如也~</p>
<% } %>

<% users.forEach(function(u) { %>
<div class="forum-topic" style="display:flex;align-items:center;gap:12px">
  <img src="<%= u.avatar || '/img/default-avatar.png' %>" style="width:40px;height:40px;border:2px var(--border-style) var(--border)">
  <div style="flex:1">
    <%- include('widget/user-name', { u: u }) %>
    <span style="color:var(--text-muted);font-size:12px;margin-left:4px">@<%= u.username %></span>
    <div style="font-size:11px;color:var(--text-muted)"><%= (u.bio || '').slice(0, 60) %></div>
  </div>
  <% if (user && user.id !== u.id) { %>
    <a href="#" onclick="toggleFollow(this,'<%= u.id %>');return false" style="font-size:11px;color:<%= u.isFollowed ? '#999' : 'var(--c)' %>;white-space:nowrap"><%= u.isFollowed ? '已关注' : '+ 关注' %></a>
  <% } %>
  <div style="font-size:11px;color:var(--text-muted)"><%- timeTag(u.followed_at, {fmt:'date'}) %></div>
</div>
<% }); %>

<%- include('widget/pagination', { page: page, totalPages: totalPages, baseUrl: '/follow/' + profile.id + '/' + listType, param: 'page' }) %>
