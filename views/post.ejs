<div class="Post">
  <div class="PostHead">
    <div class="date-wrap">
      <span class="date-day">
        <%= new Date(post.created_at).getDate() %>
      </span>
      <span class="date-month">
        <%= ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][new
          Date(post.created_at).getMonth()] %>
      </span>
    </div>
    <div class="title-wrap">
      <h2>
        <%= post.title %>
      </h2>
      <span class="submitted">
        <img src="<%= post.avatar || '/img/default-avatar.png' %>"
          style="width:20px;height:20px;border-radius:2px;vertical-align:middle;margin-right:3px">
        <a href="/users/<%= post.username %>">
          <%= post.display_name || post.username %>
        </a>
        <% var b=roleBadge(post.role || 0); %>
          <span class="lv-badge" data-level="LEVEL=<%= post.role %>"
            style="background:<%= b.bg %>;color:<%= b.color %>">
            <%= b.text %>
          </span>
          <span class="lv-badge">Lv.<%= post.level || 1 %></span> |
          <%= post.created_at.slice(0, 16) %>
            <% if (post.category) { %> | <%= post.category_name || post.category %>
                <% } %>
                  | <%= post.view_count %> 阅读
                    | <a href="#" onclick="toggleLike(event, <%= post.id %>, null)" id="like-post-<%= post.id %>"
                      style="font-size:11px;color:#999">点赞</a>
                    | <a href="#" onclick="toggleBookmark(event, <%= post.id %>)" id="bookmark-<%= post.id %>"
                      style="font-size:11px;color:#999">收藏</a>
                    | <a href="/posts/<%= post.slug %>/download" style="font-size:11px;color:#999">下载 MD</a>
                    <% if (user && (user.id===post.author_id || (user.role || 0)>= LEVEL.ADMIN)) { %>
                      | <a href="/posts/<%= post.slug %>/edit">编辑</a>
                      | <a href="/posts/<%= post.slug %>/revisions">历史</a>
                      | <form method="POST" action="/posts/<%= post.slug %>/delete-self" style="display:inline"
                        onsubmit="return confirm('确认删除？')">
                        <input type="hidden" name="_csrf" value="<%= csrf %>">
                        <button
                          style="background:none;border:none;color:#c00;cursor:pointer;font-size:11px;padding:0">删除</button>
                      </form>
                      <% } %>
                      <% if (user && (user.role || 0) >= LEVEL.MOD) { %>
                      | <form method="POST" action="/admin/posts/<%= post.slug %>/pin" style="display:inline">
                        <input type="hidden" name="_csrf" value="<%= csrf %>">
                        <button style="background:none;border:none;color:var(--c);cursor:pointer;font-size:11px;padding:0"><%= post.is_pinned ? '取消置顶' : '置顶' %></button>
                      </form>
                      <% } %>
      </span>
    </div>
  </div>
  <% if (toc && toc.length) { %>
    <details class="toc-wrap" open>
      <summary style="cursor:pointer;font-size:14px;font-weight:bold;color:var(--c);margin-bottom:8px">目录</summary>
      <ul
        style="list-style:none;padding:6px 12px;background:#fafaf5;border:1px solid #e0dbd0;border-radius:3px;font-size:13px;line-height:2;margin-bottom:12px">
        <% toc.forEach(function(h){ %>
          <li style="padding-left:<%= (h.level-2)*16 %>px"><a href="#<%= h.id %>">
              <%= h.text %>
            </a></li>
          <% }); %>
      </ul>
    </details>
    <% } %>
      <div class="PostContent"><%- post.content_html %></div>
      <% if (post.tags) { %>
        <div class="tools">标签: <% post.tags.split(',').forEach(function(t) { %><a
              href="/tags/<%= encodeURIComponent(t.trim()) %>">
              <%= t.trim() %>
            </a>
            <% }); %>
        </div>
        <% } %>
        <% if (post.license) { %>
        <div class="tools">许可: <%- post.license %></div>
        <% } %>
</div>

<!-- Top-level comments only (like Tieba) -->
<div style="margin-top:20px">
  <% var _cp=(typeof cmtPage !=='undefined' ) ? cmtPage : 1; var allTop=comments.filter(function(c){return !c.parent_id}); var cmtPerPage=10; var cmtTotalPages=Math.ceil(allTop.length / cmtPerPage); if (_cp < 1) _cp=1; if (_cp > cmtTotalPages) _cp = cmtTotalPages || 1;
    var pagedComments = allTop.slice((_cp-1)*cmtPerPage, _cp*cmtPerPage);
    %>
    <h3>评论 (<%= comments.filter(function(c){return !c.parent_id}).length %>)</h3>
    <% pagedComments.forEach(function(c) { %>
      <div class="comment"
        style="padding:6px 10px;margin-bottom:4px;<%= c.is_deleted ? 'opacity:0.5;border-color:#c00' : '' %>">
        <div style="margin-bottom:2px;line-height:1.5">
          <% if (c.is_deleted) { %><span style="color:#c00;font-size:10px">[已删除]</span><% } %>
          <img src="<%= c.avatar || '/img/default-avatar.png' %>" style="width:16px;height:16px;vertical-align:middle;margin-right:3px">
          <a href="/users/<%= c.username %>"><strong><%= c.display_name || c.username %></strong></a>
          <span class="lv-badge">Lv.<%= c.level || 1 %></span>
          <span style="color:#999;font-size:10px;margin-left:4px"><%= c.created_at.slice(5, 16) %></span>
          <% var rc=comments.filter(function(x){return x.parent_id===c.id}).length; %>
          <a href="/posts/<%= post.slug %>/comment/<%= c.id %>" style="font-size:11px;color:var(--c);margin-left:6px"><%= rc>0 ? rc+'条回复' : '回复' %></a>
          <% if (user && (user.id===c.author_id || (user.role || 0)>= LEVEL.ADMIN)) { %>
            <form method="POST" action="/posts/comments/<%= c.id %>/delete" style="display:inline" onsubmit="return confirm('确认删除？')"><input type="hidden" name="_csrf" value="<%= csrf %>"><button style="background:none;border:none;color:#c00;cursor:pointer;font-size:11px;padding:0;margin-left:4px">删除</button></form>
          <% } %>
        </div>
        <div style="font-size:13px;line-height:1.6"><%- c.content_html %></div>
      </div>
      <% }); %>
</div>

<% if (cmtTotalPages> 1) { %>
  <div class="pages-nav">
    <% var baseUrl='/' + 'posts/' + post.slug; %>
      <% for (var i=1; i <=cmtTotalPages; i++) { %>
        <% if (i===cmtPage) { %><span class="current">
            <%= i %>
          </span>
          <% } else { %><a href="<%= baseUrl %>?cp=<%= i %>">
              <%= i %>
            </a>
            <% } %>
              <% } %>
  </div>
  <% } %>
    <% if (user) { %>
      <div style="margin-top:4px;padding:10px 0">
        <form method="POST" action="/posts/<%= post.slug %>/comment">
          <input type="hidden" name="_csrf" value="<%= csrf %>">
          <%- include('comment-toolbar') %>
            <textarea name="content" placeholder="发表新评论..."
              style="width:100%;min-height:60px;padding:6px;border:1px solid #ddd;border-radius:3px;font-size:13px;font-family:inherit"></textarea>
            <button type="submit" class="cmt-btn" style="margin-top:4px">发表评论</button>
        </form>
      </div>
      <% } %>

        <input type="hidden" name="_csrf" value="<%= csrf %>">