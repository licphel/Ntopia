<h2>标签：<%= tag %></h2>
<p style="color:#999;font-size:12px;margin-bottom:12px">共 <%= posts.length %> 篇文章</p>

<% if (posts.length === 0) { %>
  <p style="color:#999;text-align:center;padding:40px 0">该标签下暂无文章。</p>
<% } %>

<% posts.forEach(function(post) { %>
  <div class="Post<%= post.is_pinned ? ' pinned' : '' %>">
    <div class="PostHead">
      <div class="date-wrap<%= post.is_pinned ? ' forum-date' : '' %>">
        <span class="date-day"><%- timeTag(post.created_at, {fmt:'day'}) %></span>
        <span class="date-month"><%- timeTag(post.created_at, {fmt:'month'}) %></span>
      </div>
      <div class="title-wrap">
        <h2><a href="/posts/<%= post.slug %>"><%= post.title %></a></h2>
        <span class="submitted">
          <img src="<%= post.avatar || '/img/default-avatar.png' %>" style="width:18px;height:18px;vertical-align:middle;margin-right:3px">
          <a href="/users/<%= post.username %>"><%= post.display_name || post.username %></a>
          <span class="lv-badge">Lv.<%= post.level || 1 %></span> |
          <%- timeTag(post.created_at) %> |
          <%= post.comment_count %> 评论 | <%= post.view_count %> 阅读
        </span>
      </div>
    </div>
    <div class="PostContent">
      <%- post.content_html.slice(0, 400) %>
      <% if (post.content_html.length > 400) { %><p><a href="/posts/<%= post.slug %>">阅读全文...</a></p><% } %>
    </div>
    <% if (post.tags) { %>
      <div class="tools">标签: <% post.tags.split(',').forEach(function(t) { %><a href="/tags/<%= encodeURIComponent(t.trim()) %>"><%= t.trim() %></a><% }); %></div>
    <% } %>
  </div>
<% }); %>

<% if (totalPages > 1) { %><%- include("pagination", { page: page, totalPages: totalPages, baseUrl: "/tags/" + encodeURIComponent(tag), param: "page" }) %><% } %>
