<style>
/* Floating preview bubble */
.ed-preview-wrap{position:relative}
.ed-preview-bubble{display:none;position:absolute;bottom:100%;left:0;right:0;margin-bottom:12px;z-index:100;
  max-height:420px;overflow-y:auto;background:#fffef9;border:2px solid var(--c);border-radius:8px;
  padding:14px 18px;box-shadow:0 8px 32px rgba(0,0,0,0.18),0 2px 8px rgba(0,0,0,0.08);
  font-size:13px;line-height:1.7;cursor:default}
/* Triangle arrow pointing down */
.ed-preview-bubble::after{content:'';position:absolute;top:100%;left:24px;border:10px solid transparent;border-top-color:var(--c)}
.ed-preview-bubble::before{content:'';position:absolute;top:100%;left:25px;border:8px solid transparent;border-top-color:#fffef9;z-index:1;margin-top:-2px}
.ed-preview-bubble h2{font-size:17px !important;margin:6px 0 8px !important;padding-bottom:3px !important;border-bottom:1px solid #e0dbd0 !important}
.ed-preview-bubble h3{font-size:14px !important;margin:10px 0 4px !important}
.ed-preview-bubble p{margin:4px 0}
.ed-preview-bubble pre{background:#2d2d2d;color:#ccc;padding:10px;overflow-x:auto;font-size:12px;border-radius:3px}
.ed-preview-bubble code{font-family:"Fira Code",Consolas,monospace;font-size:.9em}
.ed-preview-bubble blockquote{border-left:3px solid var(--c);padding:3px 10px;margin:6px 0;color:#666;background:#f8f7f4}
.ed-preview-bubble img{max-width:100%}
.ed-preview-bubble table{border-collapse:collapse;width:100%;margin:6px 0}
.ed-preview-bubble th,.ed-preview-bubble td{border:1px solid #ddd;padding:3px 6px}
.ed-preview-bubble ul,.ed-preview-bubble ol{padding-left:20px}
.ed-preview-bubble .ed-bubble-close{position:absolute;top:6px;right:10px;background:none;border:none;font-size:18px;cursor:pointer;color:#999;line-height:1}
.ed-preview-bubble .ed-bubble-close:hover{color:#333}
.ed-preview-spinner{text-align:center;color:#999;padding:20px 0}
@media(max-width:768px){.ed-preview-bubble{max-height:280px}}
</style>

<div class="editor-wrap">
  <h2><%= post ? '编辑' : '撰写' %>文章</h2>

  <% if (typeof canPost !== 'undefined' && !canPost) { %>
    <p style="color:#c00;margin-bottom:12px">每天只能发布一篇讨论文章，你今天已经发布过了。</p>
  <% } else { %>

  <form method="POST" action="<%= post ? '/posts/' + post.slug + '/edit' : '/new-post' %>">
  <input type="hidden" name="_csrf" value="<%= csrf %>">

    <label>标题</label>
    <input type="text" name="title" value="<%= post ? post.title : '' %>" required>

    <div style="display:flex;gap:12px">
      <div style="flex:1">
        <label>分类</label>
        <select name="category">
          <% if (categories && categories.length) {
            categories.forEach(function(c) { %>
              <option value="<%= c.slug %>" <%= post && post.category === c.slug ? 'selected' : '' %>><%= c.name %></option>
            <% });
          } else { %>
            <option value="">默认</option>
          <% } %>
        </select>
      </div>
      <div style="flex:2">
        <label>标签（逗号分隔）</label>
        <input type="text" name="tags" value="<%= post ? post.tags : '' %>" placeholder="技术, Python">
      </div>
    </div>

    <div style="display:flex;gap:12px">
      <div style="flex:1">
        <label>摘要</label>
        <input type="text" name="excerpt" value="<%= post ? post.excerpt : '' %>" placeholder="简短描述...">
      </div>
      <div style="width:180px">
        <label>许可协议</label>
        <select name="license">
          <% (typeof licenses !== 'undefined' ? licenses : []).forEach(function(l){ %>
            <option value="<%= l.key %>" <%= post && post.license === l.key ? 'selected' : '' %>><%= l.name %></option>
          <% }); %>
        </select>
      </div>
    </div>

    <label>正文（Markdown 格式，支持 $...$ 数学公式）</label>
    <%- include('comment-toolbar') %>
    <div class="ed-preview-wrap">
      <div class="ed-preview-bubble" id="edBubble">
        <button type="button" class="ed-bubble-close" onclick="closeBubble()" title="关闭预览">&times;</button>
        <div id="edBubbleContent"><span class="ed-preview-spinner">输入内容后自动预览...</span></div>
      </div>
      <textarea name="content" id="edContent" style="min-height:400px"><%= post ? post.content_md : '' %></textarea>
    </div>

    <input type="hidden" name="is_draft" value="0" id="is-draft-field">
    <button type="submit" class="cmt-btn" style="padding:10px 24px;font-size:15px;margin-top:8px">发布</button>
    <button type="button" class="cmt-btn" onclick="document.getElementById('is-draft-field').value='1';this.form.submit()" style="padding:10px 24px;font-size:15px;background:#999;margin-top:8px">保存草稿</button>
  </form>

  <% } %>
</div>

<input type="file" accept=".md,.markdown,.txt,text/markdown,text/plain" style="display:none" id="mdFileInput" onchange="importMdFile(this)">

<script>
(function(){
  var ta = document.getElementById('edContent');
  var bubble = document.getElementById('edBubble');
  var bubbleContent = document.getElementById('edBubbleContent');
  var timer = null;
  var lastVal = '';
  var bubbleVisible = false;
  var hideTimer = null;
  var userClosed = false; // user explicitly closed — don't auto-show until next focus

  function renderTex(){
    if (window.MathJax && MathJax.typesetPromise) {
      try { MathJax.typesetPromise([bubbleContent]).catch(function(){}); } catch(_) {}
    }
  }

  function update(){
    var val = ta.value;
    if (val === lastVal) return;
    lastVal = val;
    if (!val.trim()) { bubbleContent.innerHTML = '<span class="ed-preview-spinner">输入内容后自动预览...</span>'; return; }
    bubbleContent.innerHTML = '<span class="ed-preview-spinner">渲染中...</span>';
    fetch('/preview', {
      method: 'POST',
      headers: {'Content-Type':'application/json','x-csrf-token':'<%= csrf %>'},
      body: JSON.stringify({content: val})
    }).then(function(r){ return r.json(); }).then(function(d){
      if (d.html) { bubbleContent.innerHTML = d.html; renderTex(); }
    }).catch(function(){ bubbleContent.innerHTML = '<span style="color:#c00">预览失败</span>'; });
  }

  function showBubble(){
    if (userClosed) return;
    if (!ta.value.trim()) return;
    clearTimeout(hideTimer);
    bubble.style.display = 'block';
    bubbleVisible = true;
    update();
    // Scroll into view if needed
    var bubbleRect = bubble.getBoundingClientRect();
    if (bubbleRect.top < 0) { bubble.scrollIntoView({behavior:'smooth',block:'start'}); }
  }

  function hideBubble(){
    hideTimer = setTimeout(function(){
      bubble.style.display = 'none';
      bubbleVisible = false;
    }, 200);
  }

  window.closeBubble = function(){
    userClosed = true;
    bubble.style.display = 'none';
    bubbleVisible = false;
    clearTimeout(hideTimer);
  };

  // Show bubble on focus
  ta.addEventListener('focus', function(){
    userClosed = false;
    showBubble();
  });

  // Hide on blur with delay (allows clicking in bubble)
  ta.addEventListener('blur', function(){
    hideBubble();
  });

  // Keep bubble visible when hovering over it
  bubble.addEventListener('mouseenter', function(){
    clearTimeout(hideTimer);
  });
  bubble.addEventListener('mouseleave', function(){
    hideBubble();
  });

  // Update preview on input
  ta.addEventListener('input', function(){
    clearTimeout(timer);
    timer = setTimeout(update, 300);
    if (!bubbleVisible && ta.value.trim() && !userClosed) {
      showBubble();
    }
  });

  // Initial preview if editing existing post
  if (ta.value.trim()) update();

  // Scroll bubble independently — prevent textarea scroll from affecting bubble
  bubble.addEventListener('wheel', function(e){ e.stopPropagation(); });

  // ── Keyboard shortcut: Ctrl+Shift+P to toggle preview ──────────
  ta.addEventListener('keydown', function(e){
    if (e.ctrlKey && e.shiftKey && e.key === 'P') {
      e.preventDefault();
      if (bubbleVisible) { closeBubble(); } else { userClosed = false; showBubble(); }
    }
  });
})();

// ── MD file import ─────────────────────────────────────────────
function importMdFile(inp){
  var file = inp.files[0];
  if (!file) return;
  var reader = new FileReader();
  reader.onload = function(e){
    var ta = document.getElementById('edContent');
    var text = e.target.result;
    if (ta.value.trim() && !confirm('当前编辑区已有内容，导入 .md 文件将替换现有内容。是否继续？')) {
      inp.value = ''; return;
    }
    ta.value = text;
    ta.dispatchEvent(new Event('input', {bubbles:true}));
    ta.focus();
  };
  reader.readAsText(file);
  inp.value = '';
}
</script>
