  <script>
    // ── Poster slideshow ──────────────────────────────────────────
    (function () {
      var imgs = document.querySelectorAll('#PosterBar img');
      var dots = document.querySelectorAll('#PosterBar .p-dots span');
      if (!imgs.length) return;
      var cur = 0, timer = null, total = imgs.length;
      function show(i) {
        imgs[cur].classList.remove('active');
        if (dots.length) dots[cur].classList.remove('active');
        cur = ((i % total) + total) % total;
        imgs[cur].classList.add('active');
        if (dots.length) dots[cur].classList.add('active');
      }
      function next() { show(cur + 1); }
      window.posterNext = next;
      window.posterPrev = function () { show(cur - 1); };
      window.posterGo = function (i) { show(i); resetTimer(); };
      function resetTimer() { clearInterval(timer); timer = setInterval(next, 5000); }
      resetTimer();
      document.getElementById('PosterBar').addEventListener('mouseenter', function () { clearInterval(timer); });
      document.getElementById('PosterBar').addEventListener('mouseleave', resetTimer);
    })();

    // Preserve scroll position across page reloads
    (function () {
      var key = 'ntopia_scroll_' + location.pathname;
      var saved = sessionStorage.getItem(key);
      if (saved) {
        // Restore on next paint after images/embeds settle
        var y = parseInt(saved, 10);
        if (y > 0) {
          var restore = function () {
            window.scrollTo(0, y);
            if (Math.abs(window.scrollY - y) > 50) {
              requestAnimationFrame(function () { window.scrollTo(0, y); });
            }
          };
          requestAnimationFrame(restore);
          setTimeout(restore, 200);
        }
        sessionStorage.removeItem(key);
      }
      // Save scroll on navigation and periodically
      var save = function () { sessionStorage.setItem(key, window.scrollY); };
      var ticking = false;
      window.addEventListener('scroll', function () {
        if (!ticking) { requestAnimationFrame(function () { save(); ticking = false; }); ticking = true; }
      }, { passive: true });
      window.addEventListener('beforeunload', save);
    })();
  </script>

  <script>
    (function () {
      var M = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
      function p(n) { return n < 10 ? '0' + n : n }
      document.querySelectorAll('time.local-time').forEach(function (el) {
        var d = new Date(el.dateTime), f = el.getAttribute('data-fmt') || 'datetime';
        if (f === 'day') el.textContent = d.getDate();
        else if (f === 'month') el.textContent = M[d.getMonth()];
        else if (f === 'date') el.textContent = d.getFullYear() + '-' + p(d.getMonth() + 1) + '-' + p(d.getDate());
        else if (f === 'short') el.textContent = p(d.getMonth() + 1) + '-' + p(d.getDate()) + ' ' + p(d.getHours()) + ':' + p(d.getMinutes());
        else if (f === 'year') el.textContent = d.getFullYear();
        else el.textContent = d.getFullYear() + '-' + p(d.getMonth() + 1) + '-' + p(d.getDate()) + ' ' + p(d.getHours()) + ':' + p(d.getMinutes());
      });
    })();
  </script>

  <div id="ntopiaModalOverlay" onclick="if(event.target===this)nmCancel()">
    <div id="ntopiaModalBox">
      <p id="nmMsg"></p>
      <input type="text" id="nmInput" style="display:none">
      <div id="ntopiaModalBtns">
        <button class="nm-cancel" id="nmCancelBtn" style="display:none" onclick="nmCancel()">取消</button>
        <button class="nm-ok" id="nmOkBtn" onclick="nmOk()">确定</button>
      </div>
    </div>
  </div>

  <script>
    var _nmResolve = null;
    function nmShow(msg, opts) {
      opts = opts || {};
      document.getElementById('nmMsg').innerHTML = msg;
      var inp = document.getElementById('nmInput');
      var cancelBtn = document.getElementById('nmCancelBtn');
      if (opts.type === 'prompt') {
        inp.style.display = 'block'; inp.value = opts.inputVal || '';
        cancelBtn.style.display = 'inline-block';
      } else {
        inp.style.display = 'none';
        cancelBtn.style.display = opts.type === 'confirm' ? 'inline-block' : 'none';
      }
      document.getElementById('ntopiaModalOverlay').classList.add('show');
      _nmResolve = opts.resolve;
      if (opts.type === 'prompt') { inp.focus(); inp.select(); }
    }
    function nmOk() {
      document.getElementById('ntopiaModalOverlay').classList.remove('show');
      var val = document.getElementById('nmInput').value;
      if (_nmResolve) { _nmResolve(val); _nmResolve = null; }
    }
    function nmCancel() {
      document.getElementById('ntopiaModalOverlay').classList.remove('show');
      if (_nmResolve) { _nmResolve(null); _nmResolve = null; }
    }
    // ── Public API ──────────────────────────────────────────
    function ntopiaAlert(msg) {
      return new Promise(function (resolve) {
        nmShow(msg, { type: 'alert', resolve: function () { resolve(); } });
      });
    }
    function ntopiaConfirm(msg) {
      return new Promise(function (resolve) {
        nmShow(msg, { type: 'confirm', resolve: function (val) { resolve(val !== null); } });
      });
    }
    function ntopiaPrompt(msg, defVal) {
      return new Promise(function (resolve) {
        nmShow(msg, { type: 'prompt', inputVal: defVal || '', resolve: function (val) { resolve(val); } });
      });
    }
    // ── Form delete helper ────────────────────────────────────
    async function delConfirm(e, action) {
      e.preventDefault();
      var ok = await ntopiaConfirm('确认删除？');
      if (ok) {
        var f = document.createElement('form'); f.method = 'POST'; f.action = action; f.style.display = 'none';
        var csrf = document.createElement('input'); csrf.type = 'hidden'; csrf.name = '_csrf'; csrf.value = window._csrf || '<%= csrf %>';
        f.appendChild(csrf); document.body.appendChild(f); f.submit();
      }
    }
    // Global: replace all onsubmit="return confirm(...)" with custom modal
    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('form').forEach(function (f) {
        var m = (f.getAttribute('onsubmit') || '').match(/return\s+confirm\((['"])(.*?)\1\)/);
        if (m) {
          f.removeAttribute('onsubmit');
          f.addEventListener('submit', function (e) {
            e.preventDefault();
            ntopiaConfirm(m[2]).then(function (ok) { if (ok) f.submit(); });
          });
        }
      });
    });
    // Global: intercept forms/buttons with data-confirm attribute
    document.addEventListener('click', function (e) {
      var el = e.target.closest('[data-confirm]');
      if (!el) return;
      e.preventDefault();
      var msg = el.getAttribute('data-confirm');
      var action = el.getAttribute('data-action');
      ntopiaConfirm(msg).then(function (ok) {
        if (!ok) return;
        if (action) {
          // Button with data-action: create form and submit
          var f = document.createElement('form'); f.method = 'POST'; f.action = action; f.style.display = 'none';
          var csrf = document.createElement('input'); csrf.type = 'hidden'; csrf.name = '_csrf'; csrf.value = window._csrf || '';
          f.appendChild(csrf); document.body.appendChild(f); f.submit();
        } else if (el.tagName === 'BUTTON' && el.closest('form')) {
          // Submit button inside a form
          el.closest('form').submit();
        }
      });
    });
    // Keyboard: Enter = OK, Escape = Cancel
    document.addEventListener('keydown', function (e) {
      var ov = document.getElementById('ntopiaModalOverlay');
      if (!ov.classList.contains('show')) return;
      if (e.key === 'Enter') { e.preventDefault(); nmOk(); }
      if (e.key === 'Escape') { e.preventDefault(); nmCancel(); }
    });
    // ── Dropdown click-toggle ─────────────────────────────────
    document.querySelectorAll('.nav-drop').forEach(function (drop) {
      var trigger = drop.querySelector('a,span');
      trigger.addEventListener('click', function (e) {
        e.preventDefault(); e.stopPropagation();
        var wasOpen = drop.classList.contains('open');
        document.querySelectorAll('.nav-drop').forEach(function (d) { d.classList.remove('open'); });
        if (!wasOpen) drop.classList.add('open');
      });
    });
    // Click outside closes dropdowns
    document.addEventListener('click', function () {
      document.querySelectorAll('.nav-drop').forEach(function (d) { d.classList.remove('open'); });
    });
  </script>

</body>

</html>