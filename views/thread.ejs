<div style="margin-bottom:16px">
  <a href="/<%= post.type === 'forum' ? 'forum' : 'posts' %>/<%= post.slug %>" style="font-size:13px">返回 <%= post.type === 'forum' ? '主题' : '文章' %></a>
  <span style="color:#999;font-size:13px;margin-left:8px"><%= post.title %></span>
</div>

<div class="comment" style="padding:12px 14px;margin-bottom:12px;border:2px solid #058c05">
  <div style="margin-bottom:6px">
    <img src="<%= root.avatar || '/img/default-avatar.svg' %>" style="width:20px;height:20px;vertical-align:middle;margin-right:3px"><a href="/users/<%= root.username %>"><strong><%= root.display_name || root.username %></strong></a>
    <span class="lv-badge">Lv.<%= root.level || 1 %></span>
    <span style="color:#999;font-size:11px;float:right"><%= root.created_at.slice(0, 16) %></span>
  </div>
  <div style="font-size:14px;line-height:1.7"><%- root.content_html %></div>
  <div style="margin-top:8px">
    <% if (user && (user.id === root.author_id || user.role === 'admin')) { %>
      <form method="POST" action="/comments/<%= root.id %>/delete" style="display:inline" onsubmit="return confirm('确认删除？')">
        <button style="background:none;border:none;color:#c00;cursor:pointer;font-size:11px;padding:0">删除</button>
      </form>
    <% } %>
  </div>
</div>

<h4>回复 (<%= replyCount %>)</h4>
<% replies.forEach(function(c) { %>
<div class="comment" style="padding:8px 12px;margin-bottom:4px">
  <div style="margin-bottom:3px">
    <img src="<%= c.avatar || '/img/default-avatar.svg' %>" style="width:16px;height:16px;vertical-align:middle;margin-right:3px"><a href="/users/<%= c.username %>"><strong><%= c.display_name || c.username %></strong></a>
    <span class="lv-badge">Lv.<%= c.level || 1 %></span>
    <% if (c.parent_username && c.parent_id !== root.id) { %>
      <span style="color:#058c05;font-size:11px"> 回复 @<%= c.parent_display || c.parent_username %></span>
    <% } %>
    <span style="color:#999;font-size:10px;float:right"><%= c.created_at.slice(5, 16) %></span>
  </div>
  <div style="font-size:13px;line-height:1.6"><%- c.content_html %></div>
  <div style="margin-top:4px">
    <% if (user) { %>
      <button onclick="var f=document.getElementById('reply-<%= c.id %>');f.style.display=f.style.display==='none'?'block':'none';var ta=f.querySelector('textarea');ta.value='@<%= c.username %> ';ta.focus()" style="background:none;border:none;color:#058c05;cursor:pointer;font-size:11px">回复</button>
    <% } %>
    <% if (user && (user.id === c.author_id || user.role === 'admin')) { %>
      <form method="POST" action="/comments/<%= c.id %>/delete" style="display:inline" onsubmit="return confirm('确认删除？')">
        <button style="background:none;border:none;color:#c00;cursor:pointer;font-size:10px;padding:0">删除</button>
      </form>
    <% } %>
  </div>
  <% if (user) { %>
  <div id="reply-<%= c.id %>" style="display:none;margin-top:4px">
    <form method="POST" action="/posts/<%= post.slug %>/comment">
      <input type="hidden" name="parent_id" value="<%= c.id %>">
      <%- include('comment-toolbar') %>
      <textarea name="content" placeholder="回复 @<%= c.username %>..." style="width:100%;min-height:40px;padding:4px;border:1px solid #ddd;border-radius:3px;font-size:12px;font-family:inherit"></textarea>
      <button type="submit" class="cmt-btn" style="font-size:11px;padding:2px 8px;margin-top:2px">回复</button>
    </form>
  </div>
  <% } %>
</div>
<% }); %>

<% if (user) { %>
<div class="comment-form" style="margin-top:16px">
  <h4>回复此帖</h4>
  <form method="POST" action="/posts/<%= post.slug %>/comment">
    <input type="hidden" name="parent_id" value="<%= root.id %>">
    <%- include('comment-toolbar') %>
    <textarea name="content" placeholder="回复楼主..."></textarea>
    <button type="submit" class="cmt-btn">提交回复</button>
  </form>
</div>
<% } else { %>
<p style="color:#999;margin-top:16px">请<a href="/auth/login">登录</a>后回复。</p>
<% } %>
