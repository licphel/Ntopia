<div class="Post">
  <div class="PostHead">
    <div class="date-col">
      <div class="date-wrap">
        <span class="date-day">
          <%- timeTag(post.created_at, {fmt:'day'}) %>
        </span>
        <span class="date-month">
          <%- timeTag(post.created_at, {fmt:'month'}) %>
        </span>
      </div>
      <% var catUrl = (post.category_type === 'forum') ? '/forum/' + post.category : '/blog?cat=' + post.category; %>
<div class="date-cat"><% if (post.category) { %><a href="<%= catUrl %>"><%= post.category_name || post.category %></a><% } else { %>·<% } %></div>
    </div>
    <div class="title-wrap">
      <h2>
        <%= post.title %>
      </h2>
      <span class="submitted">
        <img src="<%= post.avatar || '/img/default-avatar.png' %>"
          style="width:20px;height:20px;border-radius:2px;vertical-align:middle;margin-right:3px">
        <a href="/users/<%= post.username %>">
          <%= post.display_name || post.username %>
        </a>
        <% var b=roleBadge(post.role || 0); %>
          <span class="lv-badge" data-level="LEVEL=<%= post.role %>"
            style="background:<%= b.bg %>;color:<%= b.color %>">
            <%= b.text %>
          </span>
          <span class="lv-badge">Lv.<%= post.level || 1 %></span> |
          <%- timeTag(post.created_at) %>
            <% if (post.category) { %> | <a href="<%= catUrl %>"><%= post.category_name || post.category %></a><% } %>
                | <%= post.comment_count %> 评论
                  | <%= post.view_count %> 阅读
      </span>
    </div>
  </div>
  <% if (toc && toc.length) { %>
    <details class="toc-wrap" open>
      <summary style="cursor:pointer;font-size:14px;font-weight:bold;color:var(--c);margin-bottom:8px">目录</summary>
      <ul
        style="list-style:none;padding:6px 12px;background:#fafaf5;border:1px solid #e0dbd0;border-radius:3px;font-size:13px;line-height:2;margin-bottom:12px">
        <% toc.forEach(function(h){ %>
          <li style="padding-left:<%= (h.level-2)*16 %>px"><a href="#<%= h.id %>">
              <%= h.text %>
            </a></li>
          <% }); %>
      </ul>
    </details>
    <% } %>
      <div class="PostContent"><%- post.content_html %></div>
      <div class="tools" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:4px">
        <span>
          <% if (post.tags) { %>
            标签: <% post.tags.split(',').forEach(function(t) { %><a href="/tags/<%= encodeURIComponent(t.trim()) %>"><%= t.trim() %></a> <% }); %>
          <% } %>
          <% if (post.license) { %> | 许可: <%= post.license %><% } %>
        </span>
        <span style="display:flex;gap:6px;align-items:center">
          <a href="#" onclick="toggleLike(event, <%= post.id %>, null)" id="like-post-<%= post.id %>" style="font-size:11px;color:<%= userLiked ? 'var(--c)' : '#999' %>"><%= userLiked ? '已赞' : '点赞' %><% if (likeCount) { %>(<%= likeCount %>)<% } %></a>
          <a href="#" onclick="toggleBookmark(event, <%= post.id %>)" id="bookmark-<%= post.id %>" style="font-size:11px;color:<%= userBookmarked ? 'var(--c)' : '#999' %>"><%= userBookmarked ? '已收藏' : '收藏' %><% if (bookmarkCount) { %>(<%= bookmarkCount %>)<% } %></a>
          <a href="#" onclick="submitReport('post', <%= post.id %>);return false" style="font-size:11px;color:#999">举报</a>
          <a href="#" onclick="downloadPost(event)" style="font-size:11px;color:#999">下载 MD</a>
          <a href="#" onclick="toggleCite();return false" style="font-size:11px;color:#999">CITE</a>
          <% if (user && (user.id===post.author_id || (user.role || 0)>= LEVEL.ADMIN)) { %>
            <a href="/posts/<%= post.slug %>/edit" style="font-size:11px;color:#999">编辑</a>
            <a href="/posts/<%= post.slug %>/revisions" style="font-size:11px;color:#999">历史</a>
            <a href="#" onclick="delPost(event)" style="font-size:11px;color:#c00">删除</a>
          <% } %>
          <% if (user && (user.role || 0) >= LEVEL.MOD) { %>
            <form method="POST" action="/admin/posts/<%= post.slug %>/pin" style="display:inline"><input type="hidden" name="_csrf" value="<%= csrf %>"><button style="background:none;border:none;color:var(--c);cursor:pointer;font-size:11px;padding:0"><%= post.is_pinned ? '取消置顶' : '置顶' %></button></form>
          <% } %>
        </span>
      </div>
      <pre id="citeBox" style="display:none;margin-top:8px;background:#2d2d2d;color:#ccc;padding:12px;border-radius:3px;overflow-x:auto;font-size:12px;line-height:1.5;white-space:pre-wrap"><%= bibtex %></pre>
</div>

<script>
function toggleCite(){
  var b = document.getElementById('citeBox');
  b.style.display = b.style.display === 'none' ? 'block' : 'none';
}
async function downloadPost(e){
  e.preventDefault();
  await ntopiaAlert('本文章遵循 <%= (post.license || 'All Rights Reserved').replace(/'/g, "\\'") %> 许可协议，请确保分发时合规！');
  location.href = '/posts/<%= post.slug %>/download';
}
async function delPost(e){
  e.preventDefault();
  var ok = await ntopiaConfirm('确认删除这篇文章？');
  if (ok) {
    var f = document.createElement('form');
    f.method = 'POST'; f.action = '/posts/<%= post.slug %>/delete-self'; f.style.display = 'none';
    var csrf = document.createElement('input'); csrf.type = 'hidden'; csrf.name = '_csrf'; csrf.value = '<%= csrf %>';
    f.appendChild(csrf);
    document.body.appendChild(f); f.submit();
  }
}
</script>

<!-- Top-level comments only (like Tieba) -->
<div style="margin-top:20px">
  <% var _cp=(typeof cmtPage !=='undefined' ) ? cmtPage : 1; var allTop=comments.filter(function(c){return !c.parent_id}); var cmtPerPage=10; var cmtTotalPages=Math.ceil(allTop.length / cmtPerPage); if (_cp < 1) _cp=1; if (_cp > cmtTotalPages) _cp = cmtTotalPages || 1;
    var pagedComments = allTop.slice((_cp-1)*cmtPerPage, _cp*cmtPerPage);
    %>
    <h3>评论 (<%= comments.filter(function(c){return !c.parent_id}).length %>)</h3>
    <% pagedComments.forEach(function(c) { %>
      <div class="comment"
        style="padding:6px 10px;margin-bottom:4px;<%= c.is_deleted ? 'opacity:0.5;border-color:#c00' : '' %>">
        <div style="margin-bottom:2px;line-height:1.5">
          <% if (c.is_deleted) { %><span style="color:#c00;font-size:10px">[已删除]</span><% } %>
          <img src="<%= c.avatar || '/img/default-avatar.png' %>" style="width:16px;height:16px;vertical-align:middle;margin-right:3px">
          <a href="/users/<%= c.username %>"><strong><%= c.display_name || c.username %></strong></a>
          <span class="lv-badge">Lv.<%= c.level || 1 %></span>
          <span style="color:#999;font-size:10px;margin-left:4px"><%- timeTag(c.created_at, {fmt:'short'}) %></span>
          <% var rc=comments.filter(function(x){return x.parent_id===c.id}).length; %>
          <a href="/posts/<%= post.slug %>/comment/<%= c.id %>" style="font-size:11px;color:var(--c);margin-left:6px"><%= rc>0 ? rc+'条回复' : '回复' %></a>
          <% if (user) { %><a href="#" onclick="submitReport('comment', <%= c.id %>);return false" style="font-size:10px;color:#999;margin-left:4px">举报</a><% } %>
          <% if (user && (user.id===c.author_id || (user.role || 0)>= LEVEL.ADMIN)) { %>
            <button onclick="delConfirm(event,'/posts/comments/<%= c.id %>/delete')" style="background:none;border:none;color:#c00;cursor:pointer;font-size:11px;padding:0;margin-left:4px">删除</button>
          <% } %>
        </div>
        <div style="font-size:13px;line-height:1.6"><%- c.content_html %></div>
      </div>
      <% }); %>
</div>

<% if (cmtTotalPages> 1) { %>
  <div class="pages-nav">
    <% var baseUrl='/' + 'posts/' + post.slug; %>
      <% for (var i=1; i <=cmtTotalPages; i++) { %>
        <% if (i===cmtPage) { %><span class="current">
            <%= i %>
          </span>
          <% } else { %><a href="<%= baseUrl %>?cp=<%= i %>">
              <%= i %>
            </a>
            <% } %>
              <% } %>
  </div>
  <% } %>
    <% if (user) { %>
      <div style="margin-top:4px;padding:10px 0">
        <form method="POST" action="/posts/<%= post.slug %>/comment">
          <input type="hidden" name="_csrf" value="<%= csrf %>">
          <%- include('widget/comment-toolbar') %>
            <textarea name="content" placeholder="发表新评论..."
              style="width:100%;min-height:60px;padding:6px;border:1px solid #ddd;border-radius:3px;font-size:13px;font-family:inherit"></textarea>
            <button type="submit" class="cmt-btn" style="margin-top:4px">发表评论</button>
        </form>
      </div>
      <% } %>

        <input type="hidden" name="_csrf" value="<%= csrf %>">