<h2>搜索</h2>

<div class="search-page">
  <form class="search-box" method="GET" action="/search">
    <input type="text" name="q" value="<%= query %>" placeholder="输入关键词搜索文章、板块、用户...">
    <button type="submit">搜索</button>
  </form>

  <div class="search-tabs">
    <a href="/search?q=<%= encodeURIComponent(query) %>&type=all" class="<%= type === 'all' ? 'active' : '' %>">全部</a>
    <a href="/search?q=<%= encodeURIComponent(query) %>&type=posts"
      class="<%= type === 'posts' ? 'active' : '' %>">文章</a>
    <a href="/search?q=<%= encodeURIComponent(query) %>&type=boards"
      class="<%= type === 'boards' ? 'active' : '' %>">板块</a>
    <a href="/search?q=<%= encodeURIComponent(query) %>&type=users"
      class="<%= type === 'users' ? 'active' : '' %>">用户</a>
  </div>

  <% if (!query) { %>
    <p style="color:var(--text-muted);text-align:center;padding:40px 0">输入关键词开始搜索。</p>
    <% } %>

      <% if (query && (typeof postResults !=='undefined' ? postResults.length : 0) + (typeof userResults !=='undefined'
        ? userResults.length : 0) + (typeof boardResults !=='undefined' ? boardResults.length : 0)===0) { %>
        <p style="color:var(--text-muted);text-align:center;padding:40px 0">没有找到相关内容。</p>
        <% } %>

          <% if (typeof boardResults !=='undefined' && boardResults.length) { %>
            <h3>板块 (<%= boardResults.length %>)</h3>
            <% boardResults.forEach(function(s) { %>
              <div class="forum-topic" style="display:flex;align-items:flex-start;gap:10px">
                <% if (s.image) { %><img src="<%= s.image %>"
                    style="width:32px;height:32px;border-radius:var(--radius);object-fit:cover;flex-shrink:0;margin-top:2px">
                  <% } %>
                    <div style="flex:1;min-width:0">
                      <a href="/forum/<%= s.id %>" style="font-weight:bold;font-size:14px;color:var(--text)">
                        <%= s.name %>
                      </a>
                      <span style="font-size:11px;color:var(--c);margin-left:8px">
                        <%= s.post_count || 0 %> 帖
                      </span>
                      <% if (s.description) { %>
                        <div style="font-size:12px;color:var(--text-muted);margin-top:2px">
                          <%= s.description %>
                        </div>
                        <% } %>
                    </div>
              </div>
              <% }); %>
                <% } %>

                  <% if (typeof postResults !=='undefined' && postResults.length) { %>
                    <h3>文章 (<%= postTotal %>)</h3>
                    <div style="display:flex;gap:0;font-size:12px;margin-bottom:8px">
                      <% var sbase='/search?q='+encodeURIComponent(query)+'&type='+type; %>
                      <a href="<%= sbase %>&sort=newest" style="padding:2px 8px;border:1px solid var(--border-light);<%= (sort||'newest')==='newest'?'background:var(--btn-accent-bg);color:var(--text-inverse);':'' %>">最新</a>
                      <a href="<%= sbase %>&sort=replies" style="padding:2px 8px;border:1px solid var(--border-light);border-left:none;<%= sort==='replies'?'background:var(--btn-accent-bg);color:var(--text-inverse);':'' %>">回复</a>
                      <a href="<%= sbase %>&sort=hot" style="padding:2px 8px;border:1px solid var(--border-light);border-left:none;<%= sort==='hot'?'background:var(--btn-accent-bg);color:var(--text-inverse);':'' %>">热门</a>
                    </div>
                    <% postResults.forEach(function(p) { %><%- include('widget/post-item', { post: p, excerpt: true })
                        %>
                        <% }); %>
                          <%- include('widget/pagination', { page: typeof postPage !=='undefined' ? postPage : 1,
                            totalPages: typeof postTotalPages !=='undefined' ? postTotalPages : 1, baseUrl: '/search' ,
                            extraParams: 'q=' + encodeURIComponent(typeof query !=='undefined' ? query : '' ) + '&type='
                            + (typeof type !=='undefined' ? type : 'all' ) + '&sort=' + (typeof sort !=='undefined' ? sort : 'newest') }) %>
                            <% } %>

                              <% if (typeof userResults !=='undefined' && userResults.length) { %>
                                <h3>用户 (<%= userResults.length %>)</h3>
                                <% userResults.forEach(function(u) { %>
                                  <div class="forum-topic" style="display:flex;align-items:center;gap:12px">
                                    <img src="<%= u.avatar || '/img/default-avatar.png' %>"
                                      style="width:40px;height:40px;border-radius:var(--radius);border:2px solid #e8e4d8">
                                    <div>
                                      <%- include('widget/user-name', { u: u }) %>
                                      <span style="color:var(--text-muted);font-size:12px">@<%= u.username %></span>
                                      <div style="font-size:11px;color:var(--text-muted)">
                                        <%= u.post_count %> 篇文章 | <%= (u.bio || '' ).slice(0, 60) %>
                                      </div>
                                    </div>
                                  </div>
                                  <% }); %>
                                    <% } %>
</div>