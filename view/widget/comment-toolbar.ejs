<div class="cmt-toolbar" style="margin-bottom:4px;display:flex;gap:2px;flex-wrap:wrap">
  <button type="button" onclick="tbBold(this)" title="粗体"><b>B</b></button>
  <button type="button" onclick="tbItalic(this)" title="斜体"><i>I</i></button>
  <button type="button" onclick="tbStrike(this)" title="删除线"><s>S</s></button>
  <button type="button" onclick="tbCode(this)" title="行内代码">&lt;/&gt;</button>
  <button type="button" onclick="tbLink(this)" title="链接">Link</button>
  <button type="button" onclick="tbQuote(this)" title="引用">Quote</button>
  <button type="button" onclick="tbCodeBlock(this)" title="代码块">Code</button>
  <button type="button" onclick="tbTex(this)" title="公式">TeX</button>
  <button type="button" onclick="tbUpload(this)" title="上传图片">Img</button>
  <button type="button" onclick="importMd()" title="导入 MD 文件">MD</button>
  <input type="file" accept="image/*" style="display:none" onchange="tbUploadDone(this)">
  <span style="font-size:10px;color:var(--text-muted);margin-left:4px"></span>
</div>
<style>
  .cmt-toolbar button {
    background: var(--bg-chip);
    border: 1px solid var(--border-light);
    border-radius: var(--radius);
    cursor: pointer;
    padding: 1px 6px;
    font-size: 11px;
    color: var(--text-soft)
  }

  .cmt-toolbar button:hover {
    background: var(--btn-accent-bg);
    color: var(--text-inverse);
    border-color: var(--c)
  }
</style>
<script>
  function tbFindTA(el) { var p = el.closest('.cmt-toolbar'); if (!p) return null; var form = p.closest('form') || p.parentElement; return form ? form.querySelector('textarea') : null }
  function tbIns(el, b, a) { var t = tbFindTA(el); if (!t) return; var s = t.selectionStart, e = t.selectionEnd, v = t.value; t.value = v.slice(0, s) + b + v.slice(s, e) + a + v.slice(e); t.focus(); t.selectionStart = s + b.length; t.selectionEnd = s + b.length + (e - s) }
  function tbBold(el) { tbIns(el, '**', '**') }
  function tbItalic(el) { tbIns(el, '*', '*') }
  function tbStrike(el) { tbIns(el, '~~', '~~') }
  function tbCode(el) { tbIns(el, '`', '`') }
  function tbLink(el) { tbIns(el, '[', '](url)') }
  function tbQuote(el) { tbIns(el, '\n> ', '') }
  function tbCodeBlock(el) { tbIns(el, '\n```\n', '\n```\n') }
  function tbTex(el) { tbIns(el, '$', '$') }
  function tbUpload(el) { var p = el.closest('.cmt-toolbar'); var f = p ? p.querySelectorAll('input[type=file]')[0] : null; if (f) f.click() }
  function importMd() { var f = document.getElementById('mdFileInput'); if (!f) { ntopiaAlert('MD 导入仅在文章编辑器中可用'); return; } f.click() }
  async function tbUploadDone(inp) { var p = inp.closest('.cmt-toolbar'); var s = p ? p.querySelector('span') : null; var f = inp.files[0]; if (!f) return; if (s) s.textContent = '...'; var d = new FormData(); d.append('file', f); try { var r = await fetch('/upload', { method: 'POST', body: d, headers: { 'x-csrf-token': (window._csrf || '') } }); var j = await r.json(); if (j.ok) { tbIns(inp, '![](' + j.url + ')', ''); if (s) s.textContent = 'OK' } else { if (s) s.textContent = '失败' } } catch (e) { if (s) s.textContent = '错误' } inp.value = ''; setTimeout(function () { if (s) s.textContent = '' }, 3000) }
</script>