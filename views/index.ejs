<h2>最新文章</h2>

<% if (posts.length === 0) { %>
  <p style="color:#999;text-align:center;padding:40px 0">还没有文章。</p>
<% } %>

<% posts.forEach(function(post) { %>
<div class="Post">
  <div class="PostHead">
    <div class="date-wrap">
      <span class="date-day"><%= new Date(post.created_at).getDate() %></span>
      <span class="date-month"><%= ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][new Date(post.created_at).getMonth()] %></span>
    </div>
    <div class="title-wrap">
      <h2><a href="/posts/<%= post.slug %>"><%= post.title %></a></h2>
      <span class="submitted">
        By <a href="/users/<%= post.username %>"><%= post.display_name || post.username %></a>
        <span class="lv-badge">Lv.<%= post.level || 1 %></span> |
        <%= post.created_at.slice(0, 10) %>
        <% if (post.category) { %> | <a href="/search?q=<%= encodeURIComponent(post.category) %>"><%= post.category %></a><% } %>
        | <%= post.comment_count %> 评论 | <%= post.view_count %> 阅读
      </span>
    </div>
  </div>
  <div class="PostContent">
    <%- post.excerpt || post.content_html.slice(0, 300) %>
    <% if (post.content_html.length > 300 || post.excerpt) { %>
      <p><a href="/posts/<%= post.slug %>">阅读全文...</a></p>
    <% } %>
  </div>
  <% if (post.tags) { %>
  <div class="tools">
    标签: <% post.tags.split(',').forEach(function(t) { %>
      <a href="/search?q=<%= encodeURIComponent(t.trim()) %>&type=posts"><%= t.trim() %></a>
    <% }); %>
  </div>
  <% } %>
</div>
<% }); %>

<% if (totalPages > 1) { %>
<div class="pages-nav">
  <% for (var i = 1; i <= totalPages; i++) { %>
    <% if (i === page) { %>
      <span class="current"><%= i %></span>
    <% } else { %>
      <a href="/?page=<%= i %>"><%= i %></a>
    <% } %>
  <% } %>
</div>
<% } %>
